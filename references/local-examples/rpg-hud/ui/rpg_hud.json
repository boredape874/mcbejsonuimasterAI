{
  "namespace": "rpg_hud",
  // ───────────────────────────────────────────
  // preserved_title: prefix 기반 데이터 수신
  // title 명령어에서 "prefix값" 형태로 수신
  // ───────────────────────────────────────────
  "preserved_title_base": {
    "type": "panel",
    "size": [
      0,
      0
    ],
    "$update_string|default": "bar_",
    "bindings": [
      {
        "binding_name": "#hud_title_text_string"
      },
      {
        "binding_name": "#hud_title_text_string",
        "binding_name_override": "#preserved_text",
        "binding_condition": "visibility_changed"
      },
      {
        "binding_type": "view",
        "source_property_name": "(not (#hud_title_text_string = #preserved_text) and not ((#hud_title_text_string - $update_string) = #hud_title_text_string))",
        "target_property_name": "#visible"
      },
      {
        "binding_type": "view",
        "source_property_name": "((#preserved_text - $update_string) - 0)",
        "target_property_name": "#progress"
      },
      {
        "binding_type": "view",
        "source_property_name": "((#preserved_text - ($update_string + #progress + ',')) - 0)",
        "target_property_name": "#max_value"
      }
    ]
  },
  // 각 바별 preserved_title 인스턴스
  "preserved_hp@rpg_hud.preserved_title_base": {
    "$update_string": "hpBar_"
  },
  "preserved_mana@rpg_hud.preserved_title_base": {
    "$update_string": "manaBar_"
  },
  "preserved_armor@rpg_hud.preserved_title_base": {
    "$update_string": "armorBar_"
  },
  "preserved_food@rpg_hud.preserved_title_base": {
    "$update_string": "foodBar_"
  },
  "preserved_exp@rpg_hud.preserved_title_base": {
    "$update_string": "expBar_"
  },
  // ───────────────────────────────────────────
  // 바 그룹: 왼쪽 (체력 + 마나)
  // ───────────────────────────────────────────
  "left_group": {
    "type": "panel",
    "size": [
      98,
      21
    ],
    "anchor_from": "bottom_middle",
    "anchor_to": "bottom_middle",
    "offset": [
      -50,
      -34
    ],
    "controls": [
      {
        "mana_icon": {
          "type": "image",
          "size": [
            9,
            9
          ],
          "texture": "textures/ui/rpghud/icon_mana",
          "color": [
            0.176,
            0.486,
            1.0
          ],
          "anchor_from": "top_left",
          "anchor_to": "top_left"
        }
      },
      {
        "mana_bar@animated_bar.animated_progress_bar": {
          "anchor_from": "top_left",
          "anchor_to": "top_left",
          "offset": [
            10,
            0
          ],
          "$background_size": [
            88,
            9
          ],
          "$background_texture": "textures/ui/rpghud/bar_outline",
          "$bar_texture": "textures/ui/rpghud/bar_fill",
          "$bar_color": [
            0.129,
            0.561,
            0.965
          ],
          "$max_value_binding": "#max_value",
          "$data_source": "preserved_mana",
          "$progress_binding": "#progress",
          "$ignore_text": false,
          "$text_shadow": true,
          "$text_font_scale_factor": 0.5,
          "$text_offset": [
            0,
            0
          ],
          "$text_anchor": "center",
          "$text_format": "('\u00a7z' + $progress_binding + '/' + #max_value)"
        }
      },
      {
        "health_icon": {
          "type": "image",
          "size": [
            9,
            9
          ],
          "texture": "textures/ui/rpghud/icon_heart",
          "color": [
            0.796,
            0.188,
            0.251
          ],
          "anchor_from": "bottom_left",
          "anchor_to": "bottom_left"
        }
      },
      {
        "health_bar@animated_bar.animated_progress_bar": {
          "anchor_from": "bottom_left",
          "anchor_to": "bottom_left",
          "offset": [
            10,
            0
          ],
          "$background_size": [
            88,
            9
          ],
          "$background_texture": "textures/ui/rpghud/bar_outline",
          "$bar_texture": "textures/ui/rpghud/bar_fill",
          "$bar_color": [
            0.796,
            0.188,
            0.251
          ],
          "$max_value_binding": "#max_value",
          "$data_source": "preserved_hp",
          "$progress_binding": "#progress",
          "$ignore_text": false,
          "$text_shadow": true,
          "$text_font_scale_factor": 0.5,
          "$text_offset": [
            0,
            0
          ],
          "$text_anchor": "center",
          "$text_format": "('\u00a7z' + $progress_binding + '/' + #max_value)"
        }
      }
    ]
  },
