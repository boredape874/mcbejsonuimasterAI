{
  "namespace": "shop",

  "main_panel": {
    "type": "panel",
    "size": ["100%", "100%"],
    "controls": [
      {
        "shop_form": {
          "type": "panel",
          "size": [220, 220],
          "offset": [0, 10],
          "layer": 2,
          "controls": [
            {
              "background": {
                "type": "image",
                "size": [220, 220],
                "offset": [0, 0],
                "layer": 0,
                "texture": "textures/ui/Black",
                "alpha": 0.8
              }
            },
            {
              "title": {
                "type": "label",
                "text": "#title",
                "font_type": "MinecraftTen",
                "font_size": "large",
                "layer": 1,
                "color": "white",
                "shadow": true,
                "offset": [0, -20],
                "anchor_from": "top_left",
                "anchor_to": "top_left",
                "bindings": [
                  {
                    "binding_type": "view",
                    "source_property_name": "(#title_text - 'menu.shop')",
                    "target_property_name": "#title"
                  }
                ]
              }
            },
            {
              "bg@shop.my_form_background": {}
            },
            {
              "indent_panel": {
                "type": "panel",
                "size": ["100%", "100% + 60px"],
                "controls": [
                  {
                    "content_stack": {
                      "type": "stack_panel",
                      "orientation": "vertical",
                      "size": ["100%", "100%"],
                      "controls": [
                        {
                          "padding_top": {
                            "type": "panel",
                            "size": ["100%", 8]
                          }
                        },
                        {
                          "padding_mid_1": {
                            "type": "panel",
                            "size": ["100%", 8]
                          }
                        },
                        {
                          "shop_body_display@shop.shop_body_display": {}
                        },
                        {
                          "padding_mid_2": {
                            "type": "panel",
                            "size": ["100%", 8]
                          }
                        },
                        {
                          "buttons_wrap": {
                            "type": "panel",
                            "size": ["100%", 150],
                            "controls": [
                              {
                                "buttons_scroll@common.scrolling_panel": {
                                  "anchor_from": "top_left",
                                  "anchor_to": "top_left",
                                  "layer": 10,
                                  "offset": [0, 0],
                                  "size": ["100% + 2px", "100% + 30px"],
                                  "$show_background": false,
                                  "$scrolling_content": "shop.shop_buttons_scrolling_content",
                                  "$scroll_size": [5, "100% - 4px"],
                                  "$scrolling_pane_size": ["100% - 10px", "100% - 2px"],
                                  "$scrolling_pane_offset": [0, 0],
                                  "$scroll_bar_right_padding_size": [0, 0]
                                }
                              }
                            ]
                          }
                        }
                      ]
                    }
                  }
                ]
              }
            },
            {
              "close@close_button": {
                "anchor_from": "top_right",
                "anchor_to": "top_right",
                "$size": [15, 15],
                "offset": [0, -20]
              }
            }
          ],
          "bindings": [
            {
              "binding_type": "view",
              "source_property_name": "(not (#title_text - 'menu.shop' = #title_text))",
              "target_property_name": "#visible"
            }
          ]
        }
      }
    ]
  },

  "shop_body_display": {
    "type": "panel",
    "size": ["100%", 30],
    "layer": 8,
    "controls": [
      {
        "text": {
          "type": "label",
          "text": "#form",
          "font_type": "MinecraftTen",
          "font_size": "medium",
          "layer": 9,
          "color": "white",
          "shadow": true,
          "anchor_from": "center",
          "anchor_to": "center",
          "offset": [0, 0],
          "bindings": [
            {
              "binding_type": "view",
              "source_property_name": "(#form_text - 'menu.invisible')",
              "target_property_name": "#form"
            }
          ]
        }
      }
    ]
  },

  "shop_buttons_scrolling_content": {
    "type": "stack_panel",
    "orientation": "vertical",
    "size": ["100%", "100%c"],
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "offset": [20, 0],
    "controls": [
      {
        "row1": {
          "type": "stack_panel",
          "orientation": "horizontal",
          "anchor_from": "center",
          "anchor_to": "center",
          "size": [180, 60],
          "collection_name": "form_buttons",
          "controls": [
            { "b@shop.shop_custom_button": { "collection_index": 0 } },
            { "b@shop.shop_custom_button": { "collection_index": 1 } },
            { "b@shop.shop_custom_button": { "collection_index": 2 } }
          ]
        }
      },
      {
        "row2": {
          "type": "stack_panel",
          "orientation": "horizontal",
          "anchor_from": "center",
          "anchor_to": "center",
          "size": [180, 60],
          "collection_name": "form_buttons",
          "controls": [
            { "b@shop.shop_custom_button": { "collection_index": 3 } },
            { "b@shop.shop_custom_button": { "collection_index": 4 } },
            { "b@shop.shop_custom_button": { "collection_index": 5 } }
          ]
        }
      },
      {
        "row3": {
          "type": "stack_panel",
          "orientation": "horizontal",
          "anchor_from": "center",
          "anchor_to": "center",
          "size": [180, 60],
          "collection_name": "form_buttons",
          "controls": [
            { "b@shop.shop_custom_button": { "collection_index": 6 } },
            { "b@shop.shop_custom_button": { "collection_index": 7 } },
            { "b@shop.shop_custom_button": { "collection_index": 8 } }
          ]
        }
      },
      {
        "row4": {
          "type": "stack_panel",
          "orientation": "horizontal",
          "anchor_from": "center",
          "anchor_to": "center",
          "size": [180, 60],
          "collection_name": "form_buttons",
          "controls": [
            { "b@shop.shop_custom_button": { "collection_index": 9 } },
            { "b@shop.shop_custom_button": { "collection_index": 10 } },
            { "b@shop.shop_custom_button": { "collection_index": 11 } }
          ]
        }
      },
      {
        "row5": {
          "type": "stack_panel",
          "orientation": "horizontal",
          "anchor_from": "center",
          "anchor_to": "center",
          "size": [180, 60],
          "collection_name": "form_buttons",
          "controls": [
            { "b@shop.shop_custom_button": { "collection_index": 12 } },
            { "b@shop.shop_custom_button": { "collection_index": 13 } },
            { "b@shop.shop_custom_button": { "collection_index": 14 } }
          ]
        }
      }
    ]
  },

  "shop_custom_button": {
    "$padding|default": [60, 60],
    "$button_size|default": [55, 55],
    "$icon_size|default": [25, 25],

    "type": "panel",
    "size": "$padding",
    "controls": [
      {
        "main_ui": {
          "type": "panel",
          "size": "$button_size",
          "controls": [
            {
              "form_button@common_buttons.light_text_button": {
                "$pressed_button_name": "button.form_button_click",
                "anchor_from": "top_left",
                "anchor_to": "top_left",
                "size": "$button_size",
                "$button_text": "#null",
                "$button_text_binding_type": "collection",
                "$button_text_grid_collection_name": "form_buttons",
                "$button_text_max_size": ["100%", 20],
                "default_control": "default",
                "hover_control": "hover",
                "pressed_control": "pressed",
                "bindings": [
                  {
                    "binding_type": "collection_details",
                    "binding_collection_name": "form_buttons"
                  }
                ],
                "controls": [
                  {
                    "default@common.empty_panel": {
                      "size": ["100%", "100%"],
                      "controls": [
                        {
                          "bg": {
                            "type": "image",
                            "texture": "textures/custom_ui/big_square",
                            "size": ["100%", "100%"],
                            "alpha": 0.95,
                            "keep_ratio": false
                          }
                        },
                        {
                          "icon": {
                            "type": "image",
                            "layer": 200,
                            "size": "$icon_size",
                            "anchor_from": "center",
                            "anchor_to": "center",
                            "offset": [1, -5],
                            "bindings": [
                              {
                                "binding_name": "#form_button_texture",
                                "binding_name_override": "#texture",
                                "binding_type": "collection",
                                "binding_collection_name": "form_buttons"
                              },
                              {
                                "binding_name": "#form_button_texture_file_system",
                                "binding_name_override": "#texture_file_system",
                                "binding_type": "collection",
                                "binding_collection_name": "form_buttons"
                              },
                              {
                                "binding_type": "view",
                                "source_property_name": "(not ((#texture = '') or (#texture = 'loading')))",
                                "target_property_name": "#visible"
                              }
                            ]
                          }
                        },
                        {
                          "text": {
                            "type": "label",
                            "text": "#form_button_text",
                            "font_type": "MinecraftTen",
                            "layer": 201,
                            "color": [1, 1, 1],
                            "shadow": true,
                            "anchor_from": "center",
                            "anchor_to": "center",
                            "offset": [2.5, 15],
                            "bindings": [
                              {
                                "binding_name": "#form_button_text",
                                "binding_type": "collection",
                                "binding_collection_name": "form_buttons"
                              }
                            ]
                          }
                        }
                      ]
                    }
                  },
                  {
                    "hover@common.empty_panel": {
                      "size": ["100%", "100%"],
                      "controls": [
                        {
                          "bg": {
                            "type": "image",
                            "texture": "textures/custom_ui/big_square",
                            "size": ["100%", "100%"],
                            "alpha": 1.0,
                            "keep_ratio": false
                          }
                        },
                        {
                          "icon": {
                            "type": "image",
                            "layer": 200,
                            "size": "$icon_size",
                            "anchor_from": "center",
                            "anchor_to": "center",
                            "offset": [1, -5],
                            "bindings": [
                              {
                                "binding_name": "#form_button_texture",
                                "binding_name_override": "#texture",
                                "binding_type": "collection",
                                "binding_collection_name": "form_buttons"
                              },
                              {
                                "binding_name": "#form_button_texture_file_system",
                                "binding_name_override": "#texture_file_system",
                                "binding_type": "collection",
                                "binding_collection_name": "form_buttons"
                              },
                              {
                                "binding_type": "view",
                                "source_property_name": "(not ((#texture = '') or (#texture = 'loading')))",
                                "target_property_name": "#visible"
                              }
                            ]
                          }
                        },
                        {
                          "text": {
                            "type": "label",
                            "text": "#form_button_text",
                            "font_type": "MinecraftTen",
                            "layer": 201,
                            "color": [1, 1, 1],
                            "shadow": true,
                            "anchor_from": "center",
                            "anchor_to": "center",
                            "offset": [2.5, 15],
                            "bindings": [
                              {
                                "binding_name": "#form_button_text",
                                "binding_type": "collection",
                                "binding_collection_name": "form_buttons"
                              }
                            ]
                          }
                        },
                        {
                          "focus_border@common_buttons.focus_border": {
                            "size": ["100%", "100%"]
                          }
                        }
                      ]
                    }
                  },
                  {
                    "pressed@common.empty_panel": {
                      "size": ["100%", "100%"],
                      "controls": [
                        {
                          "bg": {
                            "type": "image",
                            "texture": "textures/custom_ui/big_square",
                            "size": ["100%", "100%"],
                            "alpha": 0.85,
                            "keep_ratio": false
                          }
                        },
                        {
                          "icon": {
                            "type": "image",
                            "layer": 200,
                            "size": "$icon_size",
                            "anchor_from": "center",
                            "anchor_to": "center",
                            "offset": [1, -5],
                            "bindings": [
                              {
                                "binding_name": "#form_button_texture",
                                "binding_name_override": "#texture",
                                "binding_type": "collection",
                                "binding_collection_name": "form_buttons"
                              },
                              {
                                "binding_name": "#form_button_texture_file_system",
                                "binding_name_override": "#texture_file_system",
                                "binding_type": "collection",
                                "binding_collection_name": "form_buttons"
                              },
                              {
                                "binding_type": "view",
                                "source_property_name": "(not ((#texture = '') or (#texture = 'loading')))",
                                "target_property_name": "#visible"
                              }
                            ]
                          }
                        },
                        {
                          "text": {
                            "type": "label",
                            "text": "#form_button_text",
                            "font_type": "MinecraftTen",
                            "layer": 201,
                            "color": [1, 1, 1],
                            "shadow": true,
                            "anchor_from": "center",
                            "anchor_to": "center",
                            "offset": [2.5, 15],
                            "bindings": [
                              {
                                "binding_name": "#form_button_text",
                                "binding_type": "collection",
                                "binding_collection_name": "form_buttons"
                              }
                            ]
                          }
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      }
    ]
  },

  "my_form_background": {
    "type": "image",
    "texture": "textures/custom_ui/quest_bg",
    "keep_ratio": false,
    "layer": 2,
    "size": [215, 215]
  },

  "close_button@common.button": {
    "type": "button",
    "hover_control": "hover",
    "$size|default": [15, 15],
    "size": "$size",
    "controls": [
      {
        "image": {
          "type": "image",
          "texture": "textures/ui/Black",
          "size": "$size",
          "alpha": 0.7
        }
      },
      {
        "x": {
          "anchor_from": "center",
          "anchor_to": "center",
          "text": "x",
          "type": "label",
          "offset": [0.5, -0.5]
        }
      },
      {
        "hover@common.empty_panel": {
          "controls": [
            {
              "focus_border@common_buttons.focus_border": {
                "size": ["100%", "100%"]
              }
            }
          ]
        }
      }
    ],
    "sound_name": "random.click",
    "button_mappings": [
      {
        "from_button_id": "button.menu_select",
        "to_button_id": "button.menu_exit",
        "mapping_type": "pressed"
      },
      {
        "from_button_id": "button.menu_ok",
        "to_button_id": "button.menu_exit",
        "mapping_type": "focused"
      }
    ]
  }
}