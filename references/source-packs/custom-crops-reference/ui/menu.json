{
    "namespace": "menu",
    "main_panel": {
        "type": "panel",
        "size": [
            260,
            160
        ],
        "controls": [
            {
                "title": {
                    "type": "label",
                    "text": "#title",
                    "font_type": "MinecraftTen",
                    "font_size": "large",
                    "layer": 1,
                    "color": "white",
                    "shadow": true,
                    "offset": [
                        0,
                        -20
                    ],
                    "anchor_from": "top_left",
                    "anchor_to": "top_left",
                    "bindings": [
                        {
                            "binding_type": "view",
                            "source_property_name": "(#title_text - 'menu.menu')",
                            "target_property_name": "#title"
                        }
                    ]
                }
            },
            {
                "body": {
                    "type": "label",
                    "text": "#form",
                    "font_type": "MinecraftTen",
                    "font_size": "medium",
                    "layer": 3,
                    "color": "white",
                    "shadow": true,
                    "offset": [
                        75,
                        15
                    ],
                    "anchor_from": "top_left",
                    "anchor_to": "top_left",
                    "bindings": [
                        {
                            "binding_type": "view",
                            "source_property_name": "(#form_text - 'menu.invisible')",
                            "target_property_name": "#form"
                        }
                    ]
                }
            },
            {
                "background": {
                    "size": [
                        260,
                        160
                    ],
                    "type": "image",
                    "texture": "textures/ui/Black",
                    "alpha": 0.8,
                    "controls": [
                        {
                        "close@close_button": {
                            "anchor_from": "top_right",
                            "anchor_to": "top_right",
                            "$size": [15, 15],
                            "offset": [0, -20]
                        }
                        },
                        {
                            "close@hud_player": {
                                "anchor_from": "center",
                                "anchor_to": "center",
                                "$size": [
                                    15,
                                    15
                                ],
                                "offset": [
                                    -95,
                                    -37
                                ]
                            }
                        },
                        {
                            "close@info": {
                                "anchor_from": "center",
                                "anchor_to": "center",
                                "$size": [
                                    15,
                                    15
                                ],
                                "offset": [
                                    32,
                                    -17
                                ]
                            }
                        }
                    ]
                }
            },
            {
                "panel": {
                "type": "panel",
                "size": [325, 195],
                "controls": [
                    {
                    "stack_panel": {
                        "type": "stack_panel",
                        "orientation": "horizontal",
                        "anchor_from": "top_left",
                        "anchor_to": "top_left",
                        "size": [0, 0],

                        "collection_name": "form_buttons",

                        "controls": [
                        {
                            "b0@menu.menu_button": {
                            "collection_index": 0,

                            "$slot_size": [20, 20],
                            "$button_size": [20, 20],
                            "$offset": [239, 33],
                            "$text_offset": [238.7, 32]
                            }
                        },
                        {
                            "b1@menu.menu_button": {
                            "collection_index": 1,

                            "$slot_size": [20, 20],
                            "$button_size": [20, 20],
                            "$offset": [242, 33],
                            "$text_offset": [242, 35]
                            }
                        },
                        { "b2@menu.menu_button": { "collection_index": 2 } },
                        { "b3@menu.menu_button": { "collection_index": 3 } },
                        { "b4@menu.menu_button": { "collection_index": 4 } },
                        { "b5@menu.menu_button": { "collection_index": 5 } }
                        ]
                    }
                    }
                ]
                }
            }
        ],
        "bindings": [
            {
                "binding_type": "view",
                "source_property_name": "(not (#title_text - 'menu.menu' = #title_text))",
                "target_property_name": "#visible"
            }
        ]
    },
    "menu_button": {
        "$button_size|default": [55, 25],
        "$slot_size|default": [63.45, 282],
        "$offset|default": [-4.2, 17],
        "$text_offset|default": [-4.2, 17],
        "$alpha|default": 1.0,

        "type": "panel",
        "size": "$slot_size",
        "offset": "$offset",

        "controls": [
        {
            "main_ui": {
            "type": "panel",
            "size": "$button_size",
            "controls": [
                {
                "panel_name": {
                    "type": "panel",
                    "size": "$button_size",
                    "bindings": [
                    {
                        "binding_type": "view",
                        "source_control_name": "image",
                        "resolve_sibling_scope": true,
                        "source_property_name": "(not (#texture = ''))",
                        "target_property_name": "#visible"
                    }
                    ],
                    "controls": [
                    {
                        "text": {
                        "type": "label",
                        "text": "#form_button_text",
                        "layer": 10,
                        "$button_state_panel|default": "common_buttons.new_ui_button_panel",
                        "color": [0, 0, 0],
                        "offset": "$text_offset",
                        "anchor_from": "center",
                        "bindings": [
                            {
                            "binding_name": "#form_button_text",
                            "binding_type": "collection",
                            "binding_collection_name": "form_buttons"
                            }
                        ]
                        }
                    }
                    ]
                }
                },
                {
                "form_button@common_buttons.underline_button": {
                    "$pressed_button_name": "button.form_button_click",
                    "anchor_from": "top_left",
                    "anchor_to": "top_left",
                    "size": "$button_size",
                    "$button_text": "#null",
                    "default_control": "default",
                    "pressed_control": "hover",
                    "hover_control": "hover",
                    "offset": "$offset",
                    "$button_text_binding_type": "collection",
                    "$button_text_grid_collection_name": "form_buttons",
                    "$button_text_max_size": ["100%", 20],
                    "bindings": [
                    {
                        "binding_type": "collection_details",
                        "binding_collection_name": "form_buttons"
                    }
                    ],
                    "controls": [
                    {
                        "default@common.empty_panel": {
                        "controls": [
                            {
                            "image": {
                                "type": "image",
                                "layer": 1,
                                "size": "$button_size",
                                "alpha": "$alpha",
                                "bindings": [
                                {
                                    "binding_name": "#form_button_texture",
                                    "binding_name_override": "#texture",
                                    "binding_type": "collection",
                                    "binding_collection_name": "form_buttons"
                                },
                                {
                                    "binding_name": "#form_button_texture_file_system",
                                    "binding_name_override": "#texture_file_system",
                                    "binding_type": "collection",
                                    "binding_collection_name": "form_buttons"
                                },
                                {
                                    "binding_type": "view",
                                    "source_property_name": "(not ((#texture = '') or (#texture = 'loading')))",
                                    "target_property_name": "#visible"
                                }
                                ]
                            }
                            }
                        ]
                        }
                    },
                    {
                        "hover@common.empty_panel": {
                        "controls": [
                            {
                            "image": {
                                "type": "image",
                                "layer": 1,
                                "alpha": "$alpha",
                                "size": "$button_size",
                                "bindings": [
                                {
                                    "binding_name": "#form_button_texture",
                                    "binding_name_override": "#texture",
                                    "binding_type": "collection",
                                    "binding_collection_name": "form_buttons"
                                },
                                {
                                    "binding_name": "#form_button_texture_file_system",
                                    "binding_name_override": "#texture_file_system",
                                    "binding_type": "collection",
                                    "binding_collection_name": "form_buttons"
                                },
                                {
                                    "binding_type": "view",
                                    "source_property_name": "(not ((#texture = '') or (#texture = 'loading')))",
                                    "target_property_name": "#visible"
                                }
                                ]
                            }
                            },
                            {
                            "focus_border@common_buttons.focus_border": {
                                "layer": 2,
                                "size": ["100%", "100%"]
                            }
                            }
                        ]
                        }
                    }
                    ]
                }
                }
            ]
            }
        }
        ]
    },
    "hud_player": {
    "type": "panel",
    "size": [40, 60],
    "layer": 2,
    "anchor_from": "center",
    "anchor_to": "center",
    "controls": [
        {
        "background": {
            "type": "image",
            "texture": "textures/custom_ui/player",
            "size": [55, 115],
            "layer": 2,
            "keep_ratio": false,
            "anchor_from": "center",
            "anchor_to": "center",
            "offset": [0, "50%-10px"]
        }
        },
        {
        "player": {
            "type": "custom",
            "renderer": "live_player_renderer",
            "size": [45, 45],
            "layer": 3,
            "anchor_from": "center",
            "anchor_to": "center",
            "offset": [0, 12]
        }
        }
    ]
    },
    "info": {
        "type": "image",
        "texture": "textures/custom_ui/info",
        "keep_ratio": false,
        "size": [
            182.5, 115
        ]
    },
    "close_button@common.button": {
    "type": "button",
    "hover_control": "hover",
    "$size|default": [15, 15],
    "size": "$size",
    "controls": [
      {
        "image": {
          "type": "image",
          "texture": "textures/ui/Black",
          "size": "$size",
          "alpha": 0.7
        }
      },
      {
        "x": {
          "anchor_from": "center",
          "anchor_to": "center",
          "text": "x",
          "type": "label",
          "offset": [0.5, -0.5]
        }
      },
      {
        "hover@common.empty_panel": {
          "controls": [
            {
              "focus_border@common_buttons.focus_border": {
                "size": ["100%", "100%"]
              }
            }
          ]
        }
      }
    ],
    "sound_name": "random.click",
    "button_mappings": [
      {
        "from_button_id": "button.menu_select",
        "to_button_id": "button.menu_exit",
        "mapping_type": "pressed"
      },
      {
        "from_button_id": "button.menu_ok",
        "to_button_id": "button.menu_exit",
        "mapping_type": "focused"
      }
    ]
  }
}