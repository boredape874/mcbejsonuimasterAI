{
  "namespace": "redesign_shop_cloud_action_form",

  // Redesign Shop
  // Version: v2.1
  // Target: Cloud

  "form_base@form_common.form_base": {
    "$form_size": [ "90%", "95%" ],
    "$form_title_design": "form_common.form_title_design_base_v2",
    "$form_content": "redesign_shop_cloud_action_form.form_content_panel",
    "bindings": "$form_visible_bindings"
  },

  "form_content_panel": {
    "type": "stack_panel",
    "size": [ "100% - 4px", "100% - 4px" ],
    "controls": [
      {
        "top_option_stack_panel": {
          "type": "stack_panel",
          "size": [ "100%", "100%c" ],
          "controls": [
            {
              "top_option_panel": {
                "type": "panel",
                "size": [ "100%", "100%c" ],
                "controls": [
                  {
                    "top_option@redesign_shop_cloud_action_form.top_option_dynamic_buttons_panel": {}
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "form_panel": {
          "type": "panel",
          "size": [ "100%", "fill" ],
          "anchor_from": "center",
          "anchor_to": "center",
          "controls": [
            {
              "scrolling_panel@common.scrolling_panel": {
                "size": [ "100%", "100%" ],
                "anchor_to": "center",
                "anchor_from": "center",
                "$show_background": false,
                "$scrolling_content": "redesign_shop_cloud_action_form.item_list_dynamic_buttons_panel",
                "$scrolling_pane_size": [ "100%", "100%" ],
                "$scrolling_pane_offset": [ 0, 0 ],
                "$scroll_size": [ 5, "100% - 4px" ],
                "$scroll_bar_right_padding_size": [ 0, 0 ]
              }
            }
          ]
        }
      },
      { "1_void_panel@common.empty_panel": { "size": [ 0, 4 ] } },
      {
        "page_info_button_panel": {
          "type": "panel",
          "size": [ "100%", 24 ],
          "controls": [
            {
              "page_stack_panel": {
                "layer": 20,
                "type": "stack_panel",
                "size": [ "35%", "100%" ],
                "anchor_from": "center",
                "anchor_to": "center",
                "orientation": "horizontal",
                "controls": [
                  {
                    "page_prev@redesign_shop_cloud_action_form.page_button_stack_panel": {
                      "$page_type": "§T§P§P"
                    }
                  },
                  {
                    "page_info@redesign_shop_cloud_action_form.page_info_button_stack_panel": {
                      "size": [ "fill", "100%" ],
                      "anchor_from": "center",
                      "anchor_to": "center"
                    }
                  },
                  {
                    "page_next@redesign_shop_cloud_action_form.page_button_stack_panel": {
                      "$page_type": "§T§P§N"
                    }
                  }
                ]
              }
            }
          ]
        }
      }
    ]
  },


  // Top Option Button
  "top_option_dynamic_buttons_panel@form_template.stack_dynamic_action_form_preset": {
    "$panel_size": [ "70%", "100%cm" ],
    "$panel_orientation": "horizontal",
    "$factory_control_ids": {
      "button": "redesign_shop_cloud_action_form.top_option_dynamic_form_button",
      "label": "@form_common.empty_panel",
      "header": "@form_common.empty_panel",
      "divider": "@form_common.empty_panel"
    }
  },

  "top_option_dynamic_form_button": {
    "type": "panel",
    "size": [ "33.33%", 34 ],
    "anchor_from": "center",
    "anchor_to": "center",
    "controls": [
      {
        "dynamic_form_button@common_buttons.dark_text_button": {
          "size": [ "100%", "100% - 4px" ],
          "anchor_from": "center",
          "anchor_to": "center",

          "$pressed_button_name": "button.form_button_click",
          "$button_type_panel": "form_template.dynamic_form_button_content",

          "$button_pressed_offset": [ 0, 0 ],


          "$button_text": "#form_button_text",
          "$button_text_binding_type": "collection",
          "$button_text_grid_collection_name": "form_buttons",
          "bindings": [
            {
              "binding_name": "#form_button_text",
              "binding_type": "collection",
              "binding_collection_name": "form_buttons"
            },
            {
              "binding_type": "collection_details",
              "binding_collection_name": "form_buttons"
            }
          ]
        }
      }
    ],
    "bindings": [
      {
        "binding_type": "view",
        "source_property_name": "((not ((#form_button_text - '§T§B') = #form_button_text)))",
        "target_property_name": "#visible"
      },
      {
        "binding_name": "#form_button_text",
        "binding_type": "collection",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_type": "collection_details",
        "binding_collection_name": "form_buttons"
      }
    ]
  },


  // Next/Prev Page Button
  "page_button_stack_panel@form_template.stack_dynamic_action_form_preset": {
    "layer": 20,
    "$panel_size": [ 24, "100%" ],
    "$factory_control_ids": {
      "button": "redesign_shop_cloud_action_form.page_form_button"
    },
    "$factory_variables": [ "$page_type" ]
  },

  "page_form_button@common_buttons.dark_text_button": {
    "size": [ "100%", "100%" ],
    "anchor_from": "center",
    "anchor_to": "center",

    "$pressed_button_name": "button.form_button_click",
    "$button_type_panel": "form_template.image_with_hover_text_button_content",

    "$button_pressed_offset": [ 0, 0 ],


    "$button_text": "#form_button_text",
    "$button_text_binding_type": "collection",
    "$button_text_grid_collection_name": "form_buttons",
    "bindings": [
      {
        "binding_type": "view",
        "source_property_name": "((not ((#form_button_text - $page_type) = #form_button_text)))",
        "target_property_name": "#visible"
      },
      {
        "binding_type": "view",
        "source_property_name": "(((#form_button_text - '§B§E§F') = #form_button_text))",
        "target_property_name": "#enabled"
      },
      {
        "binding_name": "#form_button_text",
        "binding_type": "collection",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_type": "collection_details",
        "binding_collection_name": "form_buttons"
      }
    ]
  },


  // Page Info Button
  "page_info_button_stack_panel@form_template.stack_dynamic_action_form_preset": {
    "$panel_size": [ "100%", "100%" ],
    "$panel_orientation": "horizontal",
    "$factory_control_ids": {
      "button": "redesign_shop_cloud_action_form.page_info_form_button"
    }
  },

  "page_info_form_button@common_buttons.dark_text_button": {
    "enabled": false,
    "size": [ "100%", "100%" ],
    "anchor_from": "center",
    "anchor_to": "center",

    "$pressed_button_name": "button.form_button_click",

    "$button_pressed_offset": [ 0, 0 ],

    "$border_visible": false,
    "$default_button_texture": "textures/ui/empty",
    "$hover_button_texture": "textures/ui/empty",
    "$pressed_button_texture": "textures/ui/empty",
    "$locked_button_texture": "textures/ui/empty",

    "$button_text": "#form_button_text",
    "$button_text_binding_type": "collection",
    "$button_text_grid_collection_name": "form_buttons",
    "bindings": [
      {
        "binding_type": "view",
        "source_property_name": "((not ((#form_button_text - '§T§P§I') = #form_button_text)))",
        "target_property_name": "#visible"
      },
      {
        "binding_name": "#form_button_text",
        "binding_type": "collection",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_type": "collection_details",
        "binding_collection_name": "form_buttons"
      }
    ]
  },


  // Item List
  "item_list_dynamic_buttons_panel@form_template.grid_dynamic_action_form_preset": {
    "$panel_size": [ "100%", "100%c" ],
    "$button_item_template": "redesign_shop_cloud_action_form.item_dynamic_form_button"
  },

  "item_dynamic_form_button": {
    "type": "panel",
    "size": [ "10%", "100%x" ],
    "controls": [
      {
        "not_touch@redesign_shop_cloud_action_form.item_form_button": { "ignored": "$touch", "size": [ "100% - 4px", "100% - 4px" ] }
      },
      {
        "touch@redesign_shop_cloud_action_form.touch_item_form_button": { "ignored": "(not $touch)", "size": [ "100% - 4px", "100% - 4px" ] }
      }
    ]
  },

  "touch_item_form_button@redesign_shop_cloud_action_form.item_form_button": {
    "button_mappings": [
      {
        "from_button_id": "button.menu_select",
        "to_button_id": "button.menu_ok",
        "mapping_type": "pressed"
      },
      {
        "from_button_id": "button.menu_select",
        "to_button_id": "$pressed_button_name",
        "mapping_type": "double_pressed"
      }
    ]
  },

  "item_form_button@form_template.light_upgrade_button": {
    "size": [ "100%", "100%" ],
    "anchor_from": "center",
    "anchor_to": "center",

    "$pressed_button_name": "button.form_button_click",
    "$button_type_panel": "form_template.image_with_hover_text_button_content",

    "$button_pressed_offset": [ 0, 0 ],


    "$default_border_visible": false,
    "$hover_border_visible": false,
    "$pressed_border_visible": false,
    "$locked_border_visible": false,

    "$default_text_color": [ 1.0, 1.0, 1.0 ],
    "$hover_text_color": [ 1.0, 1.0, 1.0 ],
    "$pressed_text_color": [ 1.0, 1.0, 1.0 ],
    "$locked_text_color": [ 1.0, 1.0, 1.0 ],

    "$default_button_texture": "textures/ui/form/button/round_corner_button",
    "$hover_button_texture": "textures/ui/form/button/round_corner_button",
    "$pressed_button_texture": "textures/ui/form/button/round_corner_button",
    "$locked_button_texture": "textures/ui/form/button/round_corner_button",

    "$default_button_texture_color": [ 0.3, 0.3, 0.3 ],
    "$hover_button_texture_color": [ 0.55, 0.55, 0.55 ],
    "$pressed_button_texture_color": [ 0.1, 0.1, 0.1 ],
    "$locked_button_texture_color": [ 0.1, 0.1, 0.1 ],

    "$default_button_alpha": 0.7,
    "$hover_button_alpha": 0.7,
    "$pressed_button_alpha": 0.7,
    "$locked_button_alpha": 0.7,

    "bindings": [
      {
        "binding_type": "view",
        "source_property_name": "(((#form_button_text - '§T§D') = #form_button_text))",
        "target_property_name": "#enabled"
      },
      {
        "binding_type": "view",
        "source_property_name": "(((#form_button_text - '§T§P') = #form_button_text) and ((#form_button_text - '§T§B') = #form_button_text) and (not #form_button_text = ''))",
        "target_property_name": "#visible"
      },
      {
        "binding_name": "#form_button_text",
        "binding_type": "collection",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_type": "collection_details",
        "binding_collection_name": "form_buttons"
      }
    ]
  }
}