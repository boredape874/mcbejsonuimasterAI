{
  "namespace": "inbox_cloud_action_form",

  // Inbox
  // Version: v2.0
  // Target: Cloud

  "form_base@form_common.form_base": {
    "$form_size": [ "95%", "95%" ],
    "$form_title_design": "form_common.form_title_design_base_v2",
    "$form_content": "inbox_cloud_action_form.form_content_panel",
    "bindings": "$form_visible_bindings"
  },

  "form_content_panel": {
    "type": "panel",
    "size": [ "100%", "100%" ],
    "anchor_from": "center",
    "anchor_to": "center",
    "controls": [
      {
        "form_content_stack_panel": {
          "type": "stack_panel",
          "size": [ "100%", "100%" ],
          "anchor_to": "center",
          "anchor_from": "center",
          "orientation": "horizontal",
          "controls": [
            {
              "inbox_category_panel": {
                "type": "panel",
                "size": [ 140, "100%" ],
                "anchor_from": "center",
                "anchor_to": "center",
                "controls": [
                  {
                    "inbox_category@common.scrolling_panel": {
                      "size": [ "100% - 4px", "100% - 4px" ],
                      "anchor_to": "center",
                      "anchor_from": "center",
                      "$show_background": false,
                      "$scrolling_content": "inbox_cloud_action_form.inbox_category_toggles_panel",
                      "$scrolling_pane_size": [ "100%", "100%" ],
                      "$scrolling_pane_offset": [ 0, 0 ],
                      "$scroll_size": [ 5, "100% - 4px" ],
                      "$scroll_bar_right_padding_size": [ 0, 0 ]
                    }
                  }
                ]
              }
            },
            {
              "section_divider": {
                "layer": 25,
                "type": "image",
                "size": [ 4, "100%" ],
                "anchor_from": "center",
                "anchor_to": "center",
                "texture": "textures/ui/HowToPlayDivider"
              }
            },
            {
              "inbox_list_panel": {
                "type": "stack_panel",
                "size": [ "fill", "100%" ],
                "anchor_from": "center",
                "anchor_to": "center",
                "controls": [
                  {
                    "inbox_search_box_panel": {
                      "type": "panel",
                      "size": [ "100%", "100%c + 8px" ],
                      "anchor_to": "center",
                      "anchor_from": "center",
                      "bindings": [
                        {
                          "binding_type": "view",
                          "source_control_name": "inbox_category_search_cloud",
                          "source_property_name": "#toggle_state",
                          "target_property_name": "#visible"
                        }
                      ],
                      "controls": [
                        {
                          "inbox_search_edit_box@common.text_edit_box": {
                            "layer": 30,
                            "size": [ "100% - 8px", 26 ],
                            "anchor_from": "center",
                            "anchor_to": "center",

                            "$text_box_name": "inbox_search_edit_box",
                            "$place_holder_text": "검색할 내용을 입력해주세요!",
                            "$text_edit_text_control": "inbox_search",

                            "max_length": 30,
                            "$text_edit_box_label_offset": [ 18, 0 ],

                            "$magnifying_glass_enabled": true,
                            "$magnifying_glass_size": [ 12, 10 ],
                            "$magnifying_glass_offset": [ 0, -0.5 ]
                          }
                        }
                      ]
                    }
                  },
                  {
                    "inbox_list@common.scrolling_panel": {
                      "size": [ "100%", "fill" ],
                      "anchor_to": "center",
                      "anchor_from": "center",
                      "$show_background": false,
                      "$scrolling_content": "inbox_cloud_action_form.inbox_list_panel",
                      "$scrolling_pane_size": [ "100% - 4px", "100% - 4px" ],
                      "$scrolling_pane_offset": [ 2, 2 ],
                      "$scroll_size": [ 5, "100% - 4px" ],
                      "$scroll_bar_right_padding_size": [ 0, 0 ]
                    }
                  }
                ]
              }
            }
          ]
        }
      }
    ]
  },


  // Inbox Category
  "inbox_category_toggles_panel": {
    "type": "stack_panel",
    "size": [ "100%", "100%c" ],
    "anchor_from": "center",
    "anchor_to": "center",
    "$default_selector_toggle_index|default": 1,
    "controls": [
      {
        "search@inbox_cloud_action_form.inbox_category_toggle": {
          "$toggle_group_forced_index": 0,
          "$section_topic": "inbox_category_search_cloud",
          "$category_icon": "textures/ui/form/inbox/icon_search",
          "$category_name": "검색"
        }
      },
      {
        "all@inbox_cloud_action_form.inbox_category_toggle": {
          "$toggle_group_forced_index": 1,
          "$section_topic": "inbox_category_all_cloud",
          "$category_icon": "textures/ui/form/inbox/icon_all",
          "$category_name": "전체"
        }
      },
      {
        "boost@inbox_cloud_action_form.inbox_category_toggle": {
          "$toggle_group_forced_index": 2,
          "$section_topic": "inbox_category_boost_cloud",
          "$category_icon": "textures/ui/form/inbox/icon_boost",
          "$category_name": "캐시",

          "$default_texture": "textures/ui/csb_button_borderless_default",
          "$hover_texture": "textures/ui/csb_button_borderless_hover_pressed",
          "$pressed_texture": "textures/ui/csb_button_borderless_hover",
          "$pressed_no_hover_texture": "textures/ui/csb_button_borderless_pressed",

          "$default_texture_color": "$7_color_format",
          "$default_checked_texture_color": "$7_color_format",
          "$hover_texture_color": "$7_color_format",
          "$hover_checked_texture_color": "$7_color_format"
        }
      },
      {
        "server@inbox_cloud_action_form.inbox_category_toggle": {
          "$toggle_group_forced_index": 3,
          "$section_topic": "inbox_category_server_cloud",
          "$category_icon": "textures/ui/form/inbox/icon_server",
          "$category_name": "서버"
        }
      },
      {
        "exchange@inbox_cloud_action_form.inbox_category_toggle": {
          "$toggle_group_forced_index": 4,
          "$section_topic": "inbox_category_exchange_cloud",
          "$category_icon": "textures/ui/form/inbox/icon_exchange",
          "$category_name": "거래소"
        }
      },
      {
        "mail@inbox_cloud_action_form.inbox_category_toggle": {
          "$toggle_group_forced_index": 5,
          "$section_topic": "inbox_category_mail_cloud",
          "$category_icon": "textures/ui/form/inbox/icon_all",
          "$category_name": "메일"
        }
      }
    ]
  },

  "inbox_category_toggle": {
    "type": "panel",
    "size": [ "100%", 30 ],
    "anchor_from": "center",
    "anchor_to": "center",
    "controls": [
      {
        "toggle@common_toggles.dark_text_toggle_collection": {
          "size": [ "100% - 4px", "100% - 4px" ],
          "anchor_from": "center",
          "anchor_to": "center",

          "$button_type_panel": "inbox_cloud_action_form.inbox_category_toggle_content",

          "$radio_toggle_group": true,
          "$toggle_name": "inbox_category_cloud",
          "$toggle_view_binding_name": "$section_topic",
          "$toggle_group_default_selected": "$default_selector_toggle_index"
        }
      }
    ]
  },

  "inbox_category_toggle_content": {
    "type": "panel",
    "size": [ "100%", "100%" ],
    "anchor_from": "center",
    "anchor_to": "center",
    "$category_icon|default": "textures/ui/form/empty",
    "$category_name|default": "",
    "controls": [
      {
        "content": {
          "type": "stack_panel",
          "size": [ "100% - 4px", "100% - 4px" ],
          "anchor_from": "center",
          "anchor_to": "center",
          "orientation": "horizontal",
          "controls": [
            {
              "category_icon_panel": {
                "type": "panel",
                "size": [ "100%y", "100%" ],
                "controls": [
                  {
                    "category_icon": {
                      "type": "image",
                      "size": [ "90%", "90%" ],
                      "anchor_from": "center",
                      "anchor_to": "center",
                      "texture": "$category_icon"
                    }
                  }
                ]
              }
            },
            { "void_panel@common.empty_panel": { "size": [ 4, 0 ] } },
            {
              "category_name_panel": {
                "type": "panel",
                "size": [ "fill", "100%" ],
                "controls": [
                  {
                    "category_name": {
                      "type": "label",
                      "size": [ "100%", "default" ],
                      "max_size": [ "100%", "100%" ],
                      "anchor_from": "left_middle",
                      "anchor_to": "left_middle",
                      "text": "$category_name",
                      "shadow": true
                    }
                  }
                ]
              }
            }
          ]
        }
      }
    ]
  },


  // Inbox List
  "inbox_list_panel": {
    "type": "panel",
    "size": [ "100%", "100%c" ],
    "anchor_to": "center",
    "anchor_from": "center",
    "controls": [
      {
        "search@inbox_cloud_action_form.inbox_saerch_list_content_panel": {
          "$inbox_category_binding_type": "inbox_category_search_cloud",
          "$inbox_type_all": true
        }
      },
      {
        "all@inbox_cloud_action_form.inbox_list_content_panel": {
          "$inbox_category_binding_type": "inbox_category_all_cloud",
          "$inbox_type_all": true
        }
      },
      {
        "boost@inbox_cloud_action_form.inbox_list_content_panel": {
          "$inbox_category_binding_type": "inbox_category_boost_cloud",
          "$binding_text": "§M§C§B"
        }
      },
      {
        "server@inbox_cloud_action_form.inbox_list_content_panel": {
          "$inbox_category_binding_type": "inbox_category_server_cloud",
          "$binding_text": "§M§C§S"
        }
      },
      {
        "exchange@inbox_cloud_action_form.inbox_list_content_panel": {
          "$inbox_category_binding_type": "inbox_category_exchange_cloud",
          "$binding_text": "§M§C§E"
        }
      },
      {
        "mail@inbox_cloud_action_form.inbox_list_content_panel": {
          "$inbox_category_binding_type": "inbox_category_mail_cloud",
          "$binding_text": "§M§C§M"
        }
      }
    ]
  },

  "inbox_list_content_panel": {
    "type": "panel",
    "size": [ "100%", "100%c" ],
    "anchor_to": "center",
    "anchor_from": "center",
    "$inbox_category_binding_type|default": "",
    "$inbox_type_all|default": false,
    "$binding_text|default": "",
    "bindings": [
      {
        "binding_type": "view",
        "source_control_name": "$inbox_category_binding_type",
        "source_property_name": "#toggle_state",
        "target_property_name": "#visible"
      }
    ],
    "controls": [
      {
        "inbox_list_dynamic_buttons_panel@form_template.stack_dynamic_action_form_preset": {
          "$panel_size": [ "100%", "100%c" ],
          "$factory_control_ids": {
            "button": "inbox_cloud_action_form.inbox_list_dynamic_form_button"
          },
          "$factory_variables": [ "$inbox_type_all", "$binding_text" ]
        }
      }
    ]
  },

  "inbox_list_dynamic_form_button": {
    "type": "panel",
    "size": [ "100%", 40 ],
    "anchor_from": "center",
    "anchor_to": "center",
    "controls": [
      {
        "dynamic_form_button@inbox_cloud_action_form.inbox_list_dynamic_form_button_base": {}
      }
    ],
    "bindings": [
      {
        "binding_type": "view",
        "source_property_name": "($inbox_type_all or (not ((#form_button_text - $binding_text) = #form_button_text)))",
        "target_property_name": "#visible"
      },
      {
        "binding_name": "#form_button_text",
        "binding_type": "collection",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_type": "collection_details",
        "binding_collection_name": "form_buttons"
      }
    ]
  },

  "inbox_saerch_list_content_panel": {
    "type": "stack_panel",
    "size": [ "100%", "100%c" ],
    "anchor_to": "center",
    "anchor_from": "center",
    "$inbox_category_binding_type|default": "",
    "bindings": [
      {
        "binding_type": "view",
        "source_control_name": "$inbox_category_binding_type",
        "source_property_name": "#toggle_state",
        "target_property_name": "#visible"
      }
    ],
    "controls": [
      {
        "inbox_list_dynamic_buttons_panel@form_template.legacy_stack_dynamic_action_form_preset": {
          "$panel_size": [ "100%", "100%c" ],
          "$button_item_template": "inbox_cloud_action_form.inbox_saerch_list_dynamic_form_button"
        }
      }
    ]
  },

  "inbox_saerch_list_dynamic_form_button": {
    "type": "panel",
    "size": [ "100%", 40 ],
    "anchor_from": "center",
    "anchor_to": "center",
    "controls": [
      {
        "dynamic_form_button@inbox_cloud_action_form.inbox_list_dynamic_form_button_base": {}
      }
    ],
    "bindings": [
      {
        "binding_type": "view",
        "source_property_name": "((#search = '') or (not ((#form_button_text - #search) = #form_button_text)))",
        "target_property_name": "#visible"
      },
      {
        "binding_type": "view",
        "source_control_name": "inbox_search",
        "source_property_name": "#item_name",
        "target_property_name": "#search"
      },
      {
        "binding_name": "#form_button_text",
        "binding_type": "collection",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_type": "collection_details",
        "binding_collection_name": "form_buttons"
      }
    ]
  },

  "inbox_list_dynamic_form_button_base@common_buttons.dark_text_button": {
    "size": [ "100% - 4px", "100% - 4px" ],
    "anchor_from": "center",
    "anchor_to": "center",

    "$pressed_button_name": "button.form_button_click",
    "$button_type_panel": "inbox_cloud_action_form.inbox_list_dynamic_form_button_content",
    "$button_pressed_offset|default": [ 0, 0 ],

    "$button_text": "#form_button_text",
    "$button_text_binding_type": "collection",
    "$button_text_grid_collection_name": "form_buttons",
    "bindings": [
      {
        "binding_type": "collection_details",
        "binding_collection_name": "form_buttons"
      }
    ]
  },

  "inbox_list_dynamic_form_button_content@form_template.form_button_content_base": {
    "controls": [
      {
        "panel_name": {
          "type": "stack_panel",
          "size": [ "100% - 4px", "100% - 4px" ],
          "offset": [ 0, 1 ],
          "orientation": "horizontal",
          "controls": [
            {
              "image_panel@form_template.form_button_image_panel_base": {
                "$image_panel_size": [ "70%y", "100%" ],
                "$image_size": [ "100%", "100%x" ]
              }
            },
            { "void_panel@common.empty_panel": { "size": [ 2, 0 ] } },
            {
              "text_panel": {
                "type": "panel",
                "size": [ "fill", "100%" ],
                "controls": [
                  {
                    "button_text_panel": {
                      "type": "panel",
                      "size": [ "100%", "100%c" ],
                      "offset": [ 0, -1 ],
                      "anchor_from": "left_middle",
                      "anchor_to": "left_middle",
                      "controls": [
                        {
                          "button_text@common_buttons.new_ui_binding_button_label": {
                            "layer": 32,

                            "$text_alignment": "left",
                            "$button_font_scale_factor": 1.0,

                            "$button_text_size": [ "100% - 4px", "default" ],
                            "$button_text_max_size": [ "100% - 4px", "default" ]
                          }
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "unread_icon_panel": {
          "type": "panel",
          "size": [ "100%", "100%" ],
          "controls": [
            {
              "icon_image": {
                "type": "image",
                "size": [ 10, 10 ],
                "offset": [ 0, 0 ],
                "anchor_from": "right_middle",
                "anchor_to": "right_middle",
                "texture": "textures/ui/icon_new_item"
              }
            }
          ],
          "bindings": [
            {
              "binding_type": "view",
              "source_property_name": "((not ((#form_button_text - '§U§R') = #form_button_text)))",
              "target_property_name": "#visible"
            },
            {
              "binding_name": "#form_button_text",
              "binding_type": "collection",
              "binding_collection_name": "form_buttons"
            }
          ]
        }
      }
    ]
  }
}