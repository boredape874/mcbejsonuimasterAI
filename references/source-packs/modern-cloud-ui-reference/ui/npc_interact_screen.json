{
  "namespace": "npc_interact",

  "npc_screen@common.base_screen": {
    "type": "screen",
    "$screen_content": "npc_interact.npc_screen_contents",
    "button_mappings": [
      {
        "from_button_id": "button.menu_exit",
        "to_button_id": "button.menu_continue",
        "mapping_type": "global"
      }
    ]
  },

  "npc_screen_contents": {
    "type": "panel",
    "controls": [
      {
        "teacher@npc_interact.root_panel": {
          "$child_control": "npc_interact.main_content",
          "bindings": [
            {
              "binding_name": "#teacher_view_visible",
              "binding_name_override": "#visible",
              "binding_type": "global"
            }
          ]
        }
      },
      {
        "student_panel": {
          "type": "panel",
          "size": [ "100%", "100%" ],
          "controls": [
            {
              "student_content_panel": {
                "type": "panel",
                "size": [ "125%y", "75%" ],
                "anchor_from": "center",
                "anchor_to": "center",
                "controls": [
                  {
                    "student_content_background": {
                      "type": "image",
                      "size": [ "100%", "100%" ],
                      "anchor_from": "center",
                      "anchor_to": "center",
                      "texture": "textures/ui/npc_dialogue/background",
                      "controls": [
                        {
                          "student_content@npc_interact.student_view_content": {}
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ],
          "bindings": [
            {
              "binding_name": "#student_view_visible",
              "binding_name_override": "#visible",
              "binding_type": "global"
            }
          ]
        }
      },
      {
        "npc_screen_close@npc_interact.close_text": {
          "anchor_to": "bottom_left",
          "anchor_from": "bottom_left",
          "offset": [ 20, 0 ]
        }
      }
    ]
  },

  "x_light_close_button@common.light_close_button": {
    "button_mappings": [
      {
        "from_button_id": "button.menu_select",
        "to_button_id": "$close_button_to_button_id",
        "mapping_type": "pressed"
      },
      {
        "from_button_id": "button.menu_ok",
        "to_button_id": "$close_button_to_button_id",
        "mapping_type": "focused"
      },
      {
        "from_button_id": "button.menu_cancel",
        "to_button_id": "$close_button_to_button_id",
        "mapping_type": "global"
      }
    ],
    "bindings": [
      {
        "binding_name": "$visibility_binding_name",
        "binding_name_override": "#visible"
      }
    ]
  },

  // Visibility binding overtakes ignore condition, so wrap in parent that can ignore, then child can bind visibility
  "ignorable_x_light_close_button": {
    "type": "panel",
    "size": [ "100%c", "100%c" ],
    "controls": [
      { "button@npc_interact.x_light_close_button": {} }
    ]
  },


  // Teacher Screen
  "basic_content": {
    "type": "panel",
    "controls": [
      { "basic@npc_interact.basic_stack_panel": {} }
    ],
    "bindings": [
      {
        "binding_name": "#basic_visible",
        "binding_name_override": "#visible",
        "binding_type": "global"
      }
    ]
  },

  "advanced_scrolling_panel@common.scrolling_panel": {
    "$show_background": false,
    "size": [ "100%", "100%" ],
    "$scroll_size": [ 5, "100% - 8px" ],
    "$scroll_bar_left_padding_size": [ 0, 0 ],
    "$scroll_bar_right_padding_size": [ 4, 0 ],
    "$scrolling_content": "npc_interact.advanced_scrolling_content"
  },

  "advanced_scrolling_content": {
    "type": "panel",
    "size": [ "100%", "100%c" ],
    "controls": [
      { "advanced@npc_interact.advanced_stack_panel": {} }
    ],
    "bindings": [
      {
        "binding_name": "#advanced_visible",
        "binding_name_override": "#visible",
        "binding_type": "global"
      }
    ]
  },

  "maximized_action_edit@npc_interact.multiline_text_edit_control": {
    "size": [ "100%", "100%" ],
    "$text_edit_box_content_binding_name": "#maximized_action_text",
    "$text_box_name": "maximized_action_edit_box",
    "$text_edit_box_binding_condition": "visible",
    "$place_holder_text": "#maximized_placeholder_text",
    "max_length": 1024,
    "enabled_newline": true,
    "bindings": [
      {
        "binding_name": "#maximized_edit_visible",
        "binding_name_override": "#visible"
      },
      {
        "binding_name": "#maximized_placeholder_text"
      }
    ]
  },


  // Student Screen
  "student_view_content": {
    "type": "panel",
    "size": [ "100% - 12px", "100% - 12px" ],
    "controls": [
      {
        "close@npc_interact.student_close_button_holder": {
          "$close_button_to_button_id": "button.exit_student"
        }
      },
      {
        "student_view": {
          "type": "stack_panel",
          "size": [ "100% - 12px", "100% - 12px" ],
          "anchor_from": "center",
          "anchor_to": "center",
          "orientation": "horizontal",
          "controls": [
            {
              "npc_model_panel": {
                "type": "stack_panel",
                "size": [ "fill", "100%" ],
                "controls": [
                  {
                    "npc_model_panel": {
                      "type": "panel",
                      "size": [ "100%", "45%" ],
                      "controls": [
                        {
                          "title_panel": {
                            "layer": 14,
                            "type": "image",
                            "size": [ "100%c + 8px", "100%c + 6px" ],
                            "offset": [ 0, -2 ],
                            "anchor_from": "bottom_middle",
                            "anchor_to": "bottom_middle",
                            "texture": "textures/ui/hud_tip_text_background",
                            "alpha": 0.55,
                            "controls": [
                              {
                                "title": {
                                  "layer": 15,
                                  "type": "label",
                                  "size": [ "default", "default" ],
                                  "max_size": [ "default", "default" ],
                                  "text": "#title_text",
                                  "text_alignment": "center",
                                  "bindings": [
                                    {
                                      "binding_type": "global",
                                      "binding_name": "#title_text"
                                    }
                                  ]
                                }
                              }
                            ]
                          }
                        },
                        {
                          "npc_model@npc_interact.npc_model_window_panel": { "layer": 6 }
                        }
                      ]
                    }
                  },
                  { "void_panel@common.empty_panel": { "size": [ 2, 0 ] } },
                  {
                    "npc_message_panel": {
                      "type": "panel",
                      "size": [ "100%", "fill" ],
                      "controls": [
                        {
                          "npc_message_background": {
                            "type": "image",
                            "size": [ "100%", "100%" ],
                            "texture": "textures/ui/hud_tip_text_background",
                            "alpha": 0.35,
                            "controls": [
                              {
                                "text_scroll@common.scrolling_panel": {
                                  "size": [ "100% - 6px", "100% - 6px" ],
                                  "anchor_from": "center",
                                  "anchor_to": "center",
                                  "$always_handle_scrolling": false,
                                  "$jump_to_bottom_on_update": true,
                                  "$show_background": false,
                                  "$scrolling_content": "npc_interact.new_npc_message",
                                  "$scroll_size": [ 5, "100%" ],
                                  "$scroll_size_touch": "$scroll_size",
                                  "$scroll_box_visible_touch": false,
                                  "$scroll_bar_left_padding_size": [ 0, 0 ],
                                  "$scroll_bar_right_padding_size": [ 0, 0 ]
                                }
                              }
                            ]
                          }
                        }
                      ]
                    }
                  }
                ]
              }
            },
            {
              "divider@npc_interact.content_divider_base": {
                "$divider_panel_size": [ "100%c + 6px", "100%" ],
                "$divider_size": [ 1, "65%" ]
              }
            },
            {
              "npc_button_panel": {
                "type": "panel",
                "size": [ "40%", "100%" ],
                "controls": [
                  {
                    "student_buttons_scrolling_panel@npc_interact.student_buttons_stack_panel": {}
                  }
                ]
              }
            }
          ]
        }
      }
    ],
    "bindings": [
      {
        "binding_name": "#student_view_visible",
        "binding_name_override": "#visible",
        "binding_type": "global"
      }
    ]
  },

  "student_buttons_stack_panel": {
    "type": "stack_panel",
    "size": [ "100%", "100%" ],
    "anchor_from": "top_middle",
    "anchor_to": "top_middle",
    "collection_name": "student_buttons_collection",
    "controls": [
      { "void_padding@common.empty_panel": { "size": [ 0, 18 ] } },
      { "button_1@npc_interact.new_student_button": { "collection_index": 0 } },
      { "button_2@npc_interact.new_student_button": { "collection_index": 1 } },
      { "button_3@npc_interact.new_student_button": { "collection_index": 2 } },
      { "button_4@npc_interact.new_student_button": { "collection_index": 3 } },
      { "button_5@npc_interact.new_student_button": { "collection_index": 4 } },
      { "button_6@npc_interact.new_student_button": { "collection_index": 5 } }
    ]
  },

  "npc_model_window_panel": {
    "type": "panel",
    "size": [ "100%", "100%" ],
    "controls": [
      { "model@npc_interact.clipped_message_model": {} },
      {
        "immersive_reader_button@im_reader.reader_button": {
          "ignored": "($is_worldbuilder or not $education_edition)",
          "layer": 5,
          "size": [ 18, 18 ],
          "offset": [ 0, -4 ],
          "anchor_from": "bottom_middle",
          "anchor_to": "bottom_middle",
          "$button_tts_name|default": "key.immersivereader",
          "bindings": [
            {
              "binding_name": "#im_reader_button_visible",
              "binding_name_override": "#visible"
            }
          ]
        }
      }
    ]
  },

  "new_npc_message@npc_interact.multiline_text_edit_control": {
    "$enabled": true,
    "size": [ "100%", "100%cm" ],
    "enabled": "$enabled",
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "$text_background_default": "npc_interact.edit_box_background",
    "$text_background_hover": "npc_interact.edit_box_background",
    "$text_box_text_color": [ 1.0, 1.0, 1.0 ],
    "$text_box_name": "student_message_bubble",
    "$text_edit_box_content_binding_name": "#dialogtext",
    "$color": [ 1.0, 1.0, 1.0 ],
    "$disabled_alpha": 1,
    "max_length": 1000,
    "constrain_to_rect": false,
    "$text_edit_box_placeholder_content_binding_name": "#placeholder_dialog_text",
    "$text_alpha": 1,
    "$locked_text_alpha": "$disabled_alpha",
    "$locked_color": [ 1.0, 1.0, 1.0 ],
    "variables": [
      {
        "requires": "(not $is_worldbuilder)",
        "$place_holder_text": "",
        "$enabled": false
      }
    ],
    "bindings": [],
    "locked_control": "background",
    "default_control": "background",
    "hover_control": "background",
    "pressed_control": "background",
    "text_control": "label",
    "place_holder_control": "place_holder",
    "controls": [
      {
        "label@common.text_edit_box_label": {
          "layer": 1,
          "size": [ "100%", "default" ],
          "anchor_from": "top_middle",
          "anchor_to": "top_middle",
          "text_alignment": "center",
          "$text_box_text_color": [ 1.0, 1.0, 1.0 ]
        }
      },
      {
        "visibility_panel": {
          "type": "panel",
          "size": [ "100%", "100%c" ],
          "anchor_from": "top_middle",
          "anchor_to": "top_middle",
          "controls": [
            {
              "place_holder@common.text_edit_box_place_holder_label": {
                "layer": 1,
                "size": [ "100%", "default" ],
                "anchor_from": "center",
                "anchor_to": "center",
                "text_alignment": "center",
                "$text_box_text_color": [ 1.0, 1.0, 1.0 ]
              }
            }
          ],

          "bindings": [
            {
              "binding_type": "view",
              "source_control_name": "label",
              "source_property_name": "(#item_name = '')",
              "target_property_name": "#visible",
              "resolve_sibling_scope": true
            }
          ]
        }
      },
      { "background@common.empty_panel": { "size": [ "100%", "100%sm" ] } }
    ]
  },

  "student_button_label": {
    "type": "label",
    "color": "$text_color",
    "text": "#student_button_text",
    "bindings": [
      {
        "binding_name": "#student_button_text",
        "binding_type": "collection",
        "binding_collection_name": "student_buttons_collection"
      },
      {
        "binding_name": "$visible_binding",
        "binding_type": "collection",
        "binding_name_override": "#visible",
        "binding_collection_name": "student_buttons_collection"
      }
    ]
  },

  "student_button_label_panel": {
    "type": "panel",
    "size": [ "100%", "100%" ],
    "controls": [
      {
        "url@npc_interact.student_button_label": {
          "variables": [
            {
              "requires": "$default_state",
              "$text_color": "$npc_url_text_color"
            }
          ],
          "$visible_binding": "#is_url_button"
        }
      },
      {
        "command@npc_interact.student_button_label": {
          "$visible_binding": "#is_command_button"
        }
      }
    ]
  },

  "new_student_button@common.empty_panel": {
    "size": [ "100%", 26 ],
    "controls": [
      {
        "student_button@npc_interact.dynamic_button_base": {
          "layer": 4,
          "size": [ "100% - 2px", "100% - 2px" ],

          "$button_type_panel": "npc_interact.student_button_label_panel",
          "$pressed_button_name": "button.student_button",

          "$default_border_visible": false,
          "$hover_border_visible": false,
          "$pressed_border_visible": false,
          "$locked_border_visible": false,

          "$hover_button_texture_color": [ 0.7, 0.7, 0.7 ],
          "$pressed_button_texture_color": [ 0.4, 0.4, 0.4 ],
          "$locked_button_texture_color": [ 0.1, 0.1, 0.1 ],

          "$default_button_texture": "textures/ui/npc_dialogue/button_image",
          "$hover_button_texture": "textures/ui/npc_dialogue/button_image",
          "$pressed_button_texture": "textures/ui/npc_dialogue/button_image",
          "$locked_button_texture": "textures/ui/npc_dialogue/button_image",

          "bindings": [
            {
              "binding_type": "collection_details",
              "binding_collection_name": "student_buttons_collection",
              "binding_collection_prefix": "student_buttons"
            }
          ]
        }
      }
    ],
    "bindings": [
      {
        "binding_name": "#student_button_visible",
        "binding_type": "collection",
        "binding_name_override": "#visible",
        "binding_collection_name": "student_buttons_collection"
      }
    ]
  },

  "student_close_button_holder": {
    "type": "panel",
    "size": [ "100%c", "100%c" ],
    "anchor_from": "top_right",
    "anchor_to": "top_right",
    "offset": [ 0, 0 ],
    "controls": [
      {
        "close_basic@npc_interact.x_light_close_button": {
          "$close_button_to_button_id": "button.exit_basic",
          "$visibility_binding_name": "#basic_visible"
        }
      },
      {
        "close_student_edit@npc_interact.ignorable_x_light_close_button": {
          "ignored": "(not $is_worldbuilder)",
          "$close_button_to_button_id": "button.exit_student_edit",
          "$visibility_binding_name": "#student_view_visible"
        }
      },
      {
        "close_student@npc_interact.ignorable_x_light_close_button": {
          "ignored": "$is_worldbuilder",
          "$close_button_to_button_id": "button.exit_student",
          "$visibility_binding_name": "#student_view_visible"
        }
      }
    ]
  },


  // Content Utils
  "dynamic_button_base@common_buttons.light_button_assets": {
    "$button_state_panel|default": "common_buttons.new_ui_button_panel",
    "$button_type_panel|default": "common_buttons.button_content_panel",
    "$button_content|default": "common.empty_panel",

    "$button_offset|default": [ 0, 0 ],
    "$button_pressed_offset|default": [ 0, 0 ],
    "$pressed_alpha|default": 1,
    "$locked_alpha|default": 1,

    "$default_state|default": false,
    "$hover_state|default": false,
    "$pressed_state|default": false,
    "$locked_state|default": false,

    "$default_border_alpha|default": 1,

    "$default_border_layer|default": 2,
    "$hover_border_layer|default": 3,
    "$pressed_border_layer|default": 3,
    "$locked_border_layer|default": 1,

    "$default_border_visible|default": true,
    "$hover_border_visible|default": true,
    "$pressed_border_visible|default": true,
    "$locked_border_visible|default": true,

    "$default_text_color|default": [ 1.0, 1.0, 1.0 ],
    "$hover_text_color|default": [ 1.0, 1.0, 1.0 ],
    "$pressed_text_color|default": [ 1.0, 1.0, 1.0 ],
    "$locked_text_color|default": [ 1.0, 1.0, 1.0 ],

    "$default_button_texture_color|default": [ 1.0, 1.0, 1.0 ],
    "$hover_button_texture_color|default": [ 1.0, 1.0, 1.0 ],
    "$pressed_button_texture_color|default": [ 1.0, 1.0, 1.0 ],
    "$locked_button_texture_color|default": [ 1.0, 1.0, 1.0 ],

    "$default_button_alpha|default": 1,
    "$hover_button_alpha|default": 1,
    "$pressed_button_alpha|default": 1,
    "$locked_button_alpha|default": 1,

    "$button_text_binding_type|default": "none",
    "$button_binding_condition|default": "none",
    "$button_text_grid_collection_name|default": "",

    "controls": [
      {
        "default@$button_state_panel": {
          "layer": 1,
          "$default_state": true,
          "$new_ui_button_texture": "$default_button_texture",
          "$glyph_color": "$light_glyph_default_color",
          "$content_alpha": "$default_content_alpha",
          "$text_color": "$default_text_color",
          "$secondary_text_color": "$light_button_secondary_default_text_color",
          "$button_alpha": "$default_button_alpha",
          "$button_image_color": "$default_button_texture_color",
          "$border_color": "$light_border_default_color",
          "$border_visible": "$default_border_visible",
          "$border_layer": "$default_border_layer",
          "$border_alpha": "$default_border_alpha"
        }
      },
      {
        "hover@$button_state_panel": {
          "layer": 1,
          "$hover_state": true,
          "$new_ui_button_texture": "$hover_button_texture",
          "$glyph_color": "$light_glyph_hover_color",
          "$content_alpha": "$hover_content_alpha",
          "$text_color": "$hover_text_color",
          "$secondary_text_color": "$light_button_secondary_hover_text_color",
          "$button_alpha": "$hover_button_alpha",
          "$button_image_color": "$hover_button_texture_color",
          "$border_color": "$light_border_hover_color",
          "$border_visible": "$hover_border_visible",
          "$border_layer": "$hover_border_layer"
        }
      },
      {
        "pressed@$button_state_panel": {
          "layer": 1,
          "$pressed_state": true,
          "$new_ui_button_texture": "$pressed_button_texture",
          "$glyph_color": "$light_glyph_pressed_color",
          "$content_alpha": "$pressed_alpha",
          "$text_color": "$pressed_text_color",
          "$secondary_text_color": "$light_button_secondary_pressed_text_color",
          "$button_offset": "$button_pressed_offset",
          "$button_alpha": "$pressed_button_alpha",
          "$button_image_color": "$pressed_button_texture_color",
          "$border_color": "$light_border_pressed_color",
          "$border_visible": "$pressed_border_visible",
          "$border_layer": "$pressed_border_layer"
        }
      },
      {
        "locked@$button_state_panel": {
          "layer": 1,
          "$locked_state": true,
          "$new_ui_button_texture": "$locked_button_texture",
          "$glyph_color": "$light_glyph_locked_color",
          "$content_alpha": "$locked_alpha",
          "$text_color": "$locked_text_color",
          "$secondary_text_color": "$light_button_secondary_locked_text_color",
          "$button_alpha": "$locked_button_alpha",
          "$button_image_color": "$locked_button_texture_color",
          "$border_color": "$light_border_locked_color",
          "$border_visible": "$locked_border_visible",
          "$border_layer": "$locked_border_layer"
        }
      }
    ]
  },

  "content_divider_base": {
    "$divider_type|default": "horizontal",
    "$divider_panel_size|default": [ "100%", "100%c" ],
    "$divider_size|default": [ "65%", 1 ],
    "$divider_offset|default": [ 0, 0 ],
    "$divider_anchor|default": "center",

    "type": "panel",
    "size": "$divider_panel_size",
    "anchor_from": "center",
    "anchor_to": "center",
    "variables": [
      {
        "requires": "($divider_type = 'vertical')",
        "$divider_panel_size": [ "100%c", "100%" ],
        "$divider_size": [ 1, "65%" ]
      }
    ],
    "controls": [
      {
        "divider": {
          "type": "image",
          "size": "$divider_size",
          "offset": "$divider_offset",
          "anchor_from": "$divider_anchor",
          "anchor_to": "$divider_anchor",
          "texture": "textures/ui/list_item_divider_line_light",
          "color": [ 1.0, 1.0, 1.0 ],
          "alpha": 1.0
        }
      }
    ]
  }
}
