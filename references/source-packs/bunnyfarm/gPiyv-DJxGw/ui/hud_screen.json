{
  "namespace": "hud",

  "root_panel/sidebar": {
    "ignored": true
  },

  "root_panel": {
    "modifications": [
      {
        "array_name": "controls",
        "operation": "insert_back",
        "value": [
          {
            "upgrade_scoreboard@hud.upgrade_scoreboard_panel": {
              "bindings": [
                {
                  "binding_name": "#scoreboard_sidebar_visible",
                  "binding_name_override": "#visible"
                }
              ]
            }
          }
        ]
      }
    ]
  },

  "upgrade_scoreboard_panel": {
    "type": "panel",
    "controls": [
      {
        "vanilla_scoreboard@scoreboard.vanilla_scoreboard_sidebar": {}
      },
      {
        "custom_scoreboard@scoreboard.custom_scoreboard_sidebar": {}
      }
    ]
  }
}