{
  "hud_title_text/title_frame": {
    "bindings": [
      {
        "binding_type": "view",
        "source_control_name": "title",
        "source_property_name": "(#text - 'bar:' = #text)",
        "target_property_name": "#visible"
      }
    ]
  },
  "preserved_title": {
    "type": "panel",
    "size": [
      0,
      0
    ],
    "$update_string": "show_normal_bar:",
    "bindings": [
      {
        "binding_name": "#hud_title_text_string"
      },
      {
        "binding_name": "#hud_title_text_string",
        "binding_name_override": "#preserved_text",
        "binding_condition": "visibility_changed"
      },
      {
        "binding_type": "view",
        "source_property_name": "(not (#hud_title_text_string = #preserved_text) and not ((#hud_title_text_string - $update_string) = #hud_title_text_string))",
        "target_property_name": "#visible"
      },
      {
        "binding_type": "view",
        "source_property_name": "((#preserved_text - $update_string) + 0)",
        "target_property_name": "#progress"
      },
      {
        "binding_type": "view",
        "source_property_name": "((#preserved_text - ($update_string + #progress + ',')) + 0)",
        "target_property_name": "#max_value"
      }
    ]
  },
  "temp_title": {
    "type": "panel",
    "size": [
      0,
      0
    ],
    "$update_string": "show_temp_bar:",
    "bindings": [
      {
        "binding_name": "#hud_title_text_string"
      },
      {
        "binding_name": "#hud_title_text_string",
        "binding_name_override": "#preserved_text",
        "binding_condition": "visibility_changed"
      },
      {
        "binding_type": "view",
        "source_property_name": "(not (#hud_title_text_string = #preserved_text) and not ((#hud_title_text_string - $update_string) = #hud_title_text_string))",
        "target_property_name": "#visible"
      },
      {
        "binding_type": "view",
        "source_property_name": "((#preserved_text - $update_string) + 0)",
        "target_property_name": "#temp_progress"
      },
      {
        "binding_type": "view",
        "source_property_name": "((#preserved_text - ($update_string + #temp_progress + ',')) + 0)",
        "target_property_name": "#temp_max_value"
      }
    ]
  },
  "health_title": {
    "type": "panel",
    "size": [
      0,
      0
    ],
    "$update_string": "show_health_bar:",
    "bindings": [
      {
        "binding_name": "#hud_title_text_string"
      },
      {
        "binding_name": "#hud_title_text_string",
        "binding_name_override": "#preserved_text",
        "binding_condition": "visibility_changed"
      },
      {
        "binding_type": "view",
        "source_property_name": "(not (#hud_title_text_string = #preserved_text) and not ((#hud_title_text_string - $update_string) = #hud_title_text_string))",
        "target_property_name": "#visible"
      },
      {
        "binding_type": "view",
        "source_property_name": "((#preserved_text - $update_string) + 0)",
        "target_property_name": "#health_progress"
      },
      {
        "binding_type": "view",
        "source_property_name": "((#preserved_text - ($update_string + #health_progress + ',')) + 0)",
        "target_property_name": "#health_max_value"
      }
    ]
  },
  "root_panel": {
    "modifications": [
      {
        "array_name": "controls",
        "operation": "insert_back",
        "value": [
          {
            "normal_bar@hud.preserved_title": {}
          },
          {
            "temp_bar@hud.temp_title": {}
          },
          {
            "health_bar@hud.health_title": {}
          },
          {
            "normal_bar_wrapper": {
              "type": "panel",
              "property_bag": {
                "#visible_state": 0
              },
              "bindings": [
                {
                  "binding_name": "#hud_title_text_string"
                },
                {
                  "binding_type": "view",
                  "source_property_name": "((not ((#hud_title_text_string - 'show_normal_bar:') = #hud_title_text_string)) * 1)",
                  "target_property_name": "#trigger_on"
                },
                {
                  "binding_type": "view",
                  "source_property_name": "((not ((#hud_title_text_string - 'hide_normal_bar:') = #hud_title_text_string)) * 1)",
                  "target_property_name": "#trigger_off"
                },
                {
                  "binding_type": "view",
                  "source_property_name": "((#trigger_on or #trigger_off) * 1)",
                  "target_property_name": "#trigger_any"
                },
                {
                  "binding_type": "view",
                  "source_property_name": "(#visible_state * (1 - #trigger_any) + 1 * #trigger_on + 0 * #trigger_off)",
                  "target_property_name": "#visible_state"
                },
                {
                  "binding_type": "view",
                  "source_property_name": "(#visible_state = 1)",
                  "target_property_name": "#visible"
                }
              ],
              "controls": [
                {
                  "bar_1@animated_bar.animated_progress_bar": {
                    "$background_size": [
                      120,
                      10
                    ],
                    "$bar_size": [
                      "100% - 11px",
                      "100% - 6px"
                    ],
                    "$bar_offset": [
                      10,
                      3
                    ],
                    "offset": [
                      0,
                      80
                    ],
                    "$multiplier": 0.02,
                    "$max_value_binding": "#max_value",
                    // 1 / 50; 50 - max amount
                    "$data_source": "normal_bar",
                    // we're getting our data from the preserved_title panel above named 'bar_data'
                    "$progress_binding": "#progress",
                    // see the bindings of preserved_title to understand better

                    "$text_format": "('§z' + $progress_binding + '/' + #max_value)"
                  }
                }
              ]
            }
          },
          {
            "temp_bar_wrapper": {
              "type": "panel",
              "property_bag": {
                "#visible_state": 0
              },
              "bindings": [
                {
                  "binding_name": "#hud_title_text_string"
                },
                {
                  "binding_type": "view",
                  "source_property_name": "((not ((#hud_title_text_string - 'show_temp_bar:') = #hud_title_text_string)) * 1)",
                  "target_property_name": "#trigger_on"
                },
                {
                  "binding_type": "view",
                  "source_property_name": "((not ((#hud_title_text_string - 'hide_temp_bar:') = #hud_title_text_string)) * 1)",
                  "target_property_name": "#trigger_off"
                },
                {
                  "binding_type": "view",
                  "source_property_name": "((#trigger_on or #trigger_off) * 1)",
                  "target_property_name": "#trigger_any"
                },
                {
                  "binding_type": "view",
                  "source_property_name": "(#visible_state * (1 - #trigger_any) + 1 * #trigger_on + 0 * #trigger_off)",
                  "target_property_name": "#visible_state"
                },
                {
                  "binding_type": "view",
                  "source_property_name": "(#visible_state = 1)",
                  "target_property_name": "#visible"
                }
              ],
              "controls": [
                {
                  "temp_bar@animated_bar.animated_progress_bar": {
                    "anchor_from": "bottom_right",
                    "anchor_to": "bottom_right",
                    "offset": [
                      -10,
                      -10
                    ],
                    "$background_size": [
                      7,
                      62
                    ],
                    "$bar_size": [
                      5,
                      51
                    ],
                    "$bar_offset": [
                      1,
                      0
                    ],
                    "$bar_texture": "textures/ui/temp_bar_fixed",
                    "$background_texture": "textures/ui/temp_bar_bg_fixed",
                    "$texture_type": "fixed",
                    "$fill_from": "down",
                    "$ignore_trail": true,
                    "$multiplier": 0.02,
                    "$max_value_binding": "#temp_max_value",
                    // 1 / 50
                    "$data_source": "temp_bar",
                    "$progress_binding": "#temp_progress",
                    "$ignore_text": true
                  }
                }
              ]
            }
          },
          {
            "health_bar_wrapper": {
              "type": "panel",
              "property_bag": {
                "#visible_state": 0
              },
              "bindings": [
                {
                  "binding_name": "#hud_title_text_string"
                },
                // show_health_bar -> trigger_on [true], trigger_off [false], trigger_any [1], visible_state = 0 * (1 - 1) + 1 * 1 + 0 * 0 = 1, visible = true
                // hide_health_bar -> trigger_on [false], trigger_off [true], trigger_any [1], visible_state = 1 * (1 - 1) + 1 * 0 + 0 * 1 = 0
                // visible_state = 1, any text -> trigger_on [false], trigger_off [false], trigger_any [0], visible_state = 1 * (1 - 0) + 1 * 0 + 0 * 0 = 1
                {
                  "binding_type": "view",
                  "source_property_name": "((not ((#hud_title_text_string - 'show_health_bar:') = #hud_title_text_string)) * 1)",
                  "target_property_name": "#trigger_on"
                },
                {
                  "binding_type": "view",
                  "source_property_name": "((not ((#hud_title_text_string - 'hide_health_bar:') = #hud_title_text_string)) * 1)",
                  "target_property_name": "#trigger_off"
                },
                {
                  "binding_type": "view",
                  "source_property_name": "((#trigger_on or #trigger_off) * 1)",
                  "target_property_name": "#trigger_any"
                },
                {
                  "binding_type": "view",
                  "source_property_name": "(#visible_state * (1 - #trigger_any) + 1 * #trigger_on + 0 * #trigger_off)",
                  "target_property_name": "#visible_state"
                },
                {
                  "binding_type": "view",
                  "source_property_name": "(#visible_state = 1)",
                  "target_property_name": "#visible"
                }
              ],
              "controls": [
                {
                  "health_bar@animated_bar.animated_progress_bar": {
                    "anchor_from": "top_right",
                    "anchor_to": "top_right",
                    "offset": [
                      -10,
                      20
                    ],
                    "$background_size": [
                      80,
                      8
                    ],
                    "$bar_size": [
                      68,
                      4
                    ],
                    "$bar_offset": [
                      2,
                      2
                    ],
                    "$bar_texture": "textures/ui/health_bar_fixed",
                    "$background_texture": "textures/ui/health_bar_bg_fixed",
                    "$texture_type": "fixed",
                    "$fill_from": "right",
                    "$max_value_binding": "#health_max_value",
                    "$multiplier": 0.025,
                    "$data_source": "health_bar",
                    "$text_font_scale_factor": 0.7,
                    "$text_offset": [
                      0,
                      -8
                    ],
                    "$progress_binding": "#health_progress",
                    "$text_format|default": "('§z' + $progress_binding + '/' + #health_max_value)"
                  }
                }
              ]
            }
          }
        ]
      }
    ]
  }
}