              "from_button_id": "button.menu_select",
              "to_button_id": "button.send",
              "consume_event": true,
              "mapping_type": "pressed",
              "scope": "global"
            }
          ],
          "bindings": [
            {
              "binding_type": "view",
              "source_property_name": "('§z' + #text)",
