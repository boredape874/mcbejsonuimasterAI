              "handle_deselect": true,
              "mapping_type": "global"
            }
          ],
          "bindings": [
            {
              "binding_type": "view",
              "source_property_name": "(#selected and not #selected)",
              "target_property_name": "#selected"
            },
            {
              "binding_type": "view",
              "source_property_name": "('§z' + #text)",
              "target_property_name": "#a_text"
            },
            {
              "binding_type": "view",
              "source_property_name": "(not((#a_text - 'hover_chat') = #a_text))",
              "target_property_name": "#visible"
            }
          ],
          "controls": [
            {
