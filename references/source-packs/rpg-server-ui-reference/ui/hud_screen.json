{
  "namespace": "hud",
  
  "hud_actionbar_text/actionbar_message": {
    "$atext": "$actionbar_text",
    "visible": "(not ($atext = 'levelup'))"
  },

  "black_conditional_image": {
    "type": "image",
    "texture": "textures/custom_ui/levelup",
    "size": [ 384, 384 ],
    "anchor_from": "center",
    "anchor_to": "center",
    "offset": [ 0, "50%-185px" ],
    "layer": 10,
    "alpha": "@anim",
    "$atext": "$actionbar_text",
    "visible": "($atext = 'levelup')"
  },
  "anim": {
    "anim_type": "alpha",
    "duration": 3,
    "from": 1,
    "to": 0
  },
  "black_conditional_image_factory": {
    "type": "panel",
    "factory": {
      "name": "hud_actionbar_text_factory",
      "control_ids": {
        "hud_actionbar_text": "black_conditional_image@hud.black_conditional_image"
      }
    }
  },

  "hud_title_text/title_frame": {
    "bindings": [
      {
        "binding_type": "view",
        "source_control_name": "title",
        "source_property_name": "(#text - 'hp:' - 'xp:' - 'mp:' - 'lv:' - 'gold:' = #text)",
        "target_property_name": "#visible"
      }
    ]
  },

  "health_title": {
    "type": "panel",
    "size": [0, 0],
    "bindings": [
      { "binding_name": "#hud_title_text_string" },
      {
        "binding_name": "#hud_title_text_string",
        "binding_name_override": "#preserved_text",
        "binding_condition": "visibility_changed"
      },
      {
        "binding_type": "view",
        "source_property_name": "(not (#hud_title_text_string = #preserved_text))",
        "target_property_name": "#visible"
      },
      {
        "binding_type": "view",
        "source_property_name": "((('%.8s' * #preserved_text) - ('%.3s' * #preserved_text)) + 0)",
        "target_property_name": "#progress"
      },
      {
        "binding_type": "view",
        "source_property_name": "((('%.14s' * #preserved_text) - ('%.9s' * #preserved_text)) + 0)",
        "target_property_name": "#max_value"
      }
    ]
  },

  "exp_title": {
    "type": "panel",
    "size": [0, 0],
    "bindings": [
      { "binding_name": "#hud_title_text_string" },
      {
        "binding_name": "#hud_title_text_string",
        "binding_name_override": "#preserved_text",
        "binding_condition": "visibility_changed"
      },
      {
        "binding_type": "view",
        "source_property_name": "(not (#hud_title_text_string = #preserved_text))",
        "target_property_name": "#visible"
      },
      {
        "binding_type": "view",
        "source_property_name": "((('%.22s' * #preserved_text) - ('%.17s' * #preserved_text)) + 0)",
        "target_property_name": "#progress"
      },
      {
        "binding_type": "view",
        "source_property_name": "((('%.28s' * #preserved_text) - ('%.23s' * #preserved_text)) + 0)",
        "target_property_name": "#max_value"
      }
    ]
  },

  "mp_title": {
    "type": "panel",
    "size": [0, 0],
    "bindings": [
      { "binding_name": "#hud_title_text_string" },
      {
        "binding_name": "#hud_title_text_string",
        "binding_name_override": "#preserved_text",
        "binding_condition": "visibility_changed"
      },
      {
        "binding_type": "view",
        "source_property_name": "(not (#hud_title_text_string = #preserved_text))",
        "target_property_name": "#visible"
      },
      {
        "binding_type": "view",
        "source_property_name": "((('%.36s' * #preserved_text) - ('%.31s' * #preserved_text)) + 0)",
        "target_property_name": "#progress"
      },
      {
        "binding_type": "view",
        "source_property_name": "((('%.42s' * #preserved_text) - ('%.37s' * #preserved_text)) + 0)",
        "target_property_name": "#max_value"
      }
    ]
  },

  "lv_title": {
    "type": "panel",
    "size": [0, 0],
    "bindings": [
      { "binding_name": "#hud_title_text_string" },
      {
        "binding_name": "#hud_title_text_string",
        "binding_name_override": "#preserved_text",
        "binding_condition": "visibility_changed"
      },
      {
        "binding_type": "view",
        "source_property_name": "(not (#hud_title_text_string = #preserved_text))",
        "target_property_name": "#visible"
      },
      {
        "binding_type": "view",
        "source_property_name": "((('%.50s' * #preserved_text) - ('%.45s' * #preserved_text)) + 0)",
        "target_property_name": "#progress"
      }
    ]
  },

  "gold_title": {
    "type": "panel",
    "size": [0, 0],
    "bindings": [
      { "binding_name": "#hud_title_text_string" },
      {
        "binding_name": "#hud_title_text_string",
        "binding_name_override": "#preserved_text",
        "binding_condition": "visibility_changed"
      },
      {
        "binding_type": "view",
        "source_property_name": "(not (#hud_title_text_string = #preserved_text))",
        "target_property_name": "#visible"
      },
      {
        "binding_type": "view",
        "source_property_name": "(#preserved_text - ('%.55s' * #preserved_text))",
        "target_property_name": "#progress"
      }
    ]
  },
  
  "root_panel": {
    "modifications": [
      {
        "array_name": "controls",
        "operation": "insert_front",
        "value": {
          "black_conditional_image_factory@hud.black_conditional_image_factory": {}
        }
      },
      {
        "array_name": "controls",
        "operation": "insert_back",
        "value": [
          { "hp_data@hud.health_title": {} },
          { "xp_data@hud.exp_title": {} },
          { "mp_data@hud.mp_title": {} },
          { "lv_data@hud.lv_title": {} },
          { "gold_data@hud.gold_title": {} },
          {
            "health_bar@animated_bar.animated_progress_bar": {
              "anchor_from": "center",
              "anchor_to": "center",
              "offset": [-1, "50%-34px"],
              "$background_size": [220, 220],
              "$bar_size": [201, 5],
              "$bar_offset": [10, 108],
              "$bar_texture": "textures/custom_ui/health_bar",
              "$background_texture": "textures/custom_ui/health_bar_bg",
              "$texture_type": "fixed",
              "$fill_from": "left",
              "$data_source": "hp_data",
              "$text_font_scale_factor": 0.9,
              "$text_offset": [1, -2],
              "$text_font_type": "MinecraftTen",
              "$progress_binding": "#progress",
              "$max_value_binding": "#max_value",
              "$text_format|default": "('§z' + $progress_binding + '/' + $max_value_binding)"
            }
          },
          {
            "exp_bar@animated_bar.animated_progress_bar": {
              "anchor_from": "center",
              "anchor_to": "center",
              "offset": ["-61px", "50%-54px"],
              "$background_size": [100, 100],
              "$bar_size": [79, 3.5],
              "$bar_offset": [17, 53.5],
              "$ignore_trail": true,
              "$bar_texture": "textures/custom_ui/exp_bar",
              "$background_texture": "textures/custom_ui/exp_bar_bg",
              "$texture_type": "fixed",
              "$fill_from": "left",
              "$data_source": "xp_data",
              "$text_font_scale_factor": 0.7,
              "$text_offset": [6, 3.2],
              "$text_font_type": "MinecraftTen",
              "$progress_binding": "#progress",
              "$max_value_binding": "#max_value",
              "$text_format|default": "('§z' + $progress_binding + '/' + $max_value_binding)"
            }
          },
          {
            "mp_bar@animated_bar.animated_progress_bar": {
              "anchor_from": "center",
              "anchor_to": "center",
              "offset": ["54px", "50%-48.9px"],
              "$background_size": [88, 88],
              "$bar_size": [80, 4.9],
              "$bar_offset": [4, 41.2],
              "$ignore_trail": true,
              "$bar_texture": "textures/custom_ui/mp_bar",
              "$background_texture": "textures/custom_ui/mp_bar_bg",
              "$texture_type": "fixed",
              "$fill_from": "left",
              "$data_source": "mp_data",
              "$text_font_scale_factor": 0.7,
              "$text_offset": [0, -2.1],
              "$text_font_type": "MinecraftTen",
              "$progress_binding": "#progress",
              "$max_value_binding": "#max_value",
              "$text_format|default": "('§z' + $progress_binding + '/' + $max_value_binding)"
            }
          },
          {
            "lv_bar@animated_bar.animated_progress_bar": {
              "anchor_from": "center",
              "anchor_to": "center",
              "offset": ["-98.5px", "50%-54.5px"],
              "$trail_texture|default": "",
              "$data_source": "lv_data",
              "$text_font_scale_factor": 0.6,
              "$text_offset": [0, 0],
              "$text_color|default": [0.9098, 0.749, 0.5569, 1.0],
              "$text_font_type": "MinecraftTen",
              "$progress_binding": "#progress",
              "$text_format|default": "('§z' + $progress_binding)"
            }
          },
          {
            "gold_bar@animated_bar.animated_progress_bar": {
              "anchor_from": "center",
              "anchor_to": "center",
              "offset": ["150px", "50%-10px"],
              "$background_size": [88, 88],
              "$ignore_trail": true,
              "$background_texture": "textures/custom_ui/gold_bar",
              "$texture_type": "fixed",
              "$fill_from": "left",
              "$data_source": "gold_data",
              "$text_font_scale_factor": 0.9,
              "$text_offset": [2.5, -1.5],
              "$text_color|default": [0.9098, 0.749, 0.5569, 1.0],
              "$text_font_type": "MinecraftTen",
              "$progress_binding": "#progress",
              "$text_format|default": "('§z' + $progress_binding)"
            }
          }
        ]
      }
    ]
  }
}