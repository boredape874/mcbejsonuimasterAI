{
  "namespace": "scoreboard",

  "generic_entry_label": {
    "type": "label",
    "layer": 2,
    "text": "#player_name_sidebar",
    "localize": false,
    "color": [0.99, 0.94, 0.82],
    "size": ["default", 10],
    "max_size": [160, 20],
    "locked_alpha": 1.0,
    "bindings": [
      {
        "binding_name": "#player_name_sidebar",
        "binding_type": "collection",
        "binding_collection_name": "scoreboard_players"
      }
    ]
  },

  "generic_sidebar_entry": {
    "type": "panel",
    "size": [142, 16],
    "controls": [
      {
        "entry_bg": {
          "type": "image",
          "texture": "textures/ui/generic/generic_scoreboard_entry",
          "alpha": 0.82,
          "size": ["100%", "100%"],
          "anchor_from": "top_right",
          "anchor_to": "top_right",
          "controls": [
            {
              "name_label@scoreboard.generic_entry_label": {
                "offset": [8, 0],
                "anchor_from": "left_middle",
                "anchor_to": "left_middle"
              }
            }
          ]
        }
      }
    ],
    "bindings": [
      {
        "binding_name": "#player_name_sidebar",
        "binding_type": "collection",
        "binding_collection_name": "scoreboard_players"
      },
      {
        "binding_type": "view",
        "source_property_name": "((not ((#player_name_sidebar - '§C§O§R§E') = #player_name_sidebar)) or ((#player_name_sidebar - '§C§O§R§E') = ''))",
        "target_property_name": "#visible"
      }
    ]
  },

  "generic_sidebar": {
    "type": "panel",
    "size": [150, "100%c"],
    "anchor_from": "top_right",
    "anchor_to": "top_right",
    "offset": [-10, 46],
    "controls": [
      {
        "entry_stack": {
          "type": "stack_panel",
          "orientation": "vertical",
          "size": [142, "100%c"],
          "anchor_from": "top_right",
          "anchor_to": "top_right",
          "collection_name": "scoreboard_players",
          "factory": {
            "name": "player_list_factory",
            "control_name": "scoreboard.generic_sidebar_entry"
          },
          "bindings": [
            {
              "binding_name": "#scoreboard_sidebar_size",
              "binding_type": "global",
              "binding_name_override": "#collection_length"
            }
          ]
        }
      }
    ]
  },

  "default_entry_label": {
    "type": "label",
    "layer": 2,
    "text": "#player_name_sidebar",
    "localize": false,
    "locked_alpha": 1.0,
    "color": [0.94, 0.96, 1.0],
    "size": ["default", 11],
    "max_size": [180, 20],
    "shadow": false,
    "bindings": [
      {
        "binding_name": "#player_name_sidebar",
        "binding_type": "collection",
        "binding_collection_name": "scoreboard_players"
      },
      {
        "binding_type": "view",
        "source_property_name": "(((#player_name_sidebar - '§C§O§R§E') = #player_name_sidebar) and (not ((#player_name_sidebar - '§C§O§R§E') = '')))",
        "target_property_name": "#visible"
      }
