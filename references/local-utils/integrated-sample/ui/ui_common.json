{
  "namespace": "common",
  "highlight_slot_panel": {
    "$item_collection_name|default": "none",
    "controls": [
      {
        "highlight@common.empty_panel": {
          "controls": [
            {
              "hover_text": {
                "type": "button",
                "layer": 2344875,
                "allow_clipping": false,
                "follows_cursor": true,
                "consume_hover_events": false,
                "always_handle_pointer": true,
                "focus_enabled": false,
                "$reset": "('button.slot_' + $item_collection_name + '_reset')",
                "button_mappings": [
                  {
                    "to_button_id": "$reset",
                    "consume_event": false,
                    "mapping_type": "pressed"
                  }
                ],
                "size": [
                  18,
                  18
                ],
                "variables": [
                  {
                    "requires": "$touch",
                    "pressed_control": "default"
                  },
                  {
                    "requires": "(not $touch)",
                    "hover_control": "default"
                  }
                ],
                "controls": [
                  {
                    "default": {
                      "type": "panel",
                      "size": [
                        0,
                        0
                      ],
                      "controls": [
                        {
                          "common@common.animated_hover_text": {}
                        }
                      ]
                    }
                  }
                ],
                "bindings": [
                  {
                    "binding_name": "#item_id_aux",
                    "binding_type": "collection",
                    "binding_collection_name": "$item_collection_name"
                  },
                  {
                    "binding_name": "#hover_text",
                    "binding_type": "collection",
                    "binding_collection_name": "$item_collection_name"
                  },
                  {
                    "binding_type": "view",
                    "source_property_name": "(not (#hover_text=''))",
                    "target_property_name": "#visible"
                  },
                  {
                    "binding_type": "view",
                    "source_property_name": "(not (#item_id_aux= -1))",
                    "target_property_name": "#visible"
                  }
                ]
              }
            }
          ]
        }
      }
    ]
  },
  "ttbg": {
    "type": "image",
    "texture": "tooltip_assets/common_background",
    "size": [
      "100%c+24px",
      "100%c+10px"
    ],
    "min_size": [
      64,
      64
    ],
    "clips_children": true,
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "offset": [
      6,
      0
    ],
    "layer": 2,
    "controls": []
  },
  "ttbg_uncommon@common.ttbg": {
    "texture": "tooltip_assets/uncommon_background"
  },
  "ttbg_rare@common.ttbg": {
    "texture": "tooltip_assets/rare_background"
  },
  "ttbg_epic@common.ttbg": {
    "texture": "tooltip_assets/epic_background"
  },
  "ttbg_legendary@common.ttbg": {
    "texture": "tooltip_assets/legendary_background"
  },
  "ttbg_material@common.ttbg": {
    "texture": "tooltip_assets/material_background"
  },
  "animated_hover_text": {
    "type": "stack_panel",
    "size": [
      0,
      0
    ],
    "orientation": "vertical",
    "use_child_anchors": true,
    "controls": [
      {
        "default@common.ttbg": {
          "bindings": [
            {
              "binding_name": "#hover_text",
              "binding_type": "collection",
              "binding_collection_name": "$item_collection_name"
            },
            {
              "binding_type": "view",
              "source_property_name": "(((((#hover_text - '§U') - '§R') - '§E') - '§L') - '§M') = #hover_text",
              "target_property_name": "#visible"
            }
          ],
          "controls": [
            {
              "hover_text@common.modified_hover_text_controls": {
                "layer": 2344875
              }
            }
          ]
        }
      },
      {
        "uncommon@common.ttbg_uncommon": {
          "bindings": [
            {
              "binding_name": "#hover_text",
              "binding_type": "collection",
              "binding_collection_name": "$item_collection_name"
            },
            {
              "binding_type": "view",
              "source_property_name": "(not ((#hover_text - '§U') = #hover_text))",
              "target_property_name": "#visible"
            }
          ],
          "controls": [
            {
              "hover_text@common.modified_hover_text_controls": {
                "layer": 2344875
              }
            }
          ]
        }
      },
      {
        "rare@common.ttbg_rare": {
          "bindings": [
            {
              "binding_name": "#hover_text",
              "binding_type": "collection",
              "binding_collection_name": "$item_collection_name"
            },
            {
              "binding_type": "view",
              "source_property_name": "(not ((#hover_text - '§R') = #hover_text))",
              "target_property_name": "#visible"
            }
          ],
          "controls": [
            {
              "hover_text@common.modified_hover_text_controls": {
                "layer": 2344875
              }
            }
          ]
        }
      },
      {
        "epic@common.ttbg_epic": {
          "bindings": [
            {
              "binding_name": "#hover_text",
              "binding_type": "collection",
              "binding_collection_name": "$item_collection_name"
            },
            {
              "binding_type": "view",
              "source_property_name": "(not ((#hover_text - '§E') = #hover_text))",
              "target_property_name": "#visible"
            }
          ],
          "controls": [
            {
              "hover_text@common.modified_hover_text_controls": {
                "layer": 2344875
              }
            }
          ]
        }
      },
      {
        "legendary@common.ttbg_legendary": {
          "bindings": [
            {
              "binding_name": "#hover_text",
              "binding_type": "collection",
              "binding_collection_name": "$item_collection_name"
            },
            {
              "binding_type": "view",
              "source_property_name": "(not ((#hover_text - '§L') = #hover_text))",
              "target_property_name": "#visible"
            }
          ],
          "controls": [
            {
              "hover_text@common.modified_hover_text_controls": {
                "layer": 2344875
              }
            }
          ]
        }
      },
      {
        "material@common.ttbg_material": {
          "bindings": [
            {
              "binding_name": "#hover_text",
              "binding_type": "collection",
              "binding_collection_name": "$item_collection_name"
            },
            {
              "binding_type": "view",
              "source_property_name": "(not ((#hover_text - '§M') = #hover_text))",
              "target_property_name": "#visible"
            }
          ],
          "controls": [
            {
              "hover_text@common.modified_hover_text_controls": {
                "layer": 2344875
              }
            }
          ]
        }
      }
    ]
  },
  "modified_hover_text_controls": {
    "type": "stack_panel",
    "orientation": "vertical",
    "size": [
      "100%cm",
      "100%c"
    ],
    "controls": [
      {
        "pad": {
          "size": [
            2,
            2
          ],
          "type": "panel"
        }
      },
      {
        "hover_text_label": {
          "type": "stack_panel",
          "size": [
            "default",
            "100%cm"
          ],
          "orientation": "horizontal",
          "controls": [
            {
              "hover_text_label": {
                "size": [
                  "default",
                  "default"
                ],
                "type": "label",
                "text": "#text",
                "font_type": "$font",
                "color": "white",
                "shadow": "$shadow",
                "text_alignment": "left",
                "bindings": [
                  {
                    "binding_name": "#hover_text",
                    "binding_name_override": "#text",
                    "binding_type": "collection",
                    "binding_collection_name": "$item_collection_name"
                  },
                  {
                    "binding_type": "view",
                    "source_property_name": "(((((#text - '§f') - '§U') - '§R') - '§E') - '§L') - '§M'",
                    "target_property_name": "#text"
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "pad2": {
          "size": [
            4,
            2
          ],
          "type": "panel"
        }
      }
    ]
  },
  "selected_item_details_factory": {
    "ignored": true
  }
}