{
  "namespace": "tooltip_card_utils",
  "tooltip_text_stack": {
    "type": "stack_panel",
    "orientation": "vertical",
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "offset": [
      6,
      4
    ],
    "size": [
      "100%c",
      "100%c"
    ],
    "$content|default": [],
    "controls": "$content"
  },
  "tooltip_common_card": {
    "type": "image",
    "texture": "tooltip_assets/common_background",
    "alpha": 0.92,
    "size": [
      "100%c + 24px",
      "100%cm + 10px"
    ],
    "$content|default": [],
    "controls": "$content"
  },
