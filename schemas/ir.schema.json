{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/boredape874/mcbejsonuimasterAI/schemas/ir.schema.json",
  "title": "MCBE JSON UI IR",
  "description": "Intermediate representation for layout-only Bedrock JSON UI authoring. Compiled deterministically into JSON UI by tools/compile.mjs.",
  "type": "object",
  "additionalProperties": false,
  "required": ["screen", "elements"],
  "properties": {
    "screen": {
      "type": "string",
      "description": "Logical screen name. Used as the namespace and root panel name when compiling.",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "namespace": {
      "type": "string",
      "description": "Optional override for the JSON UI namespace. Defaults to the screen name.",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "base_resolution": {
      "type": "array",
      "description": "Reference resolution in pixels. Default [1920, 1080].",
      "items": { "type": "integer", "minimum": 320 },
      "minItems": 2,
      "maxItems": 2,
      "default": [1920, 1080]
    },
    "gui_scale": {
      "type": "integer",
      "description": "Reference GUI scale used by the renderer for visual sanity only. Does not affect compiled JSON.",
      "minimum": 1,
      "maximum": 8,
      "default": 3
    },
    "units": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allowPercent": { "type": "boolean", "default": false, "description": "Documents intent for parent-relative units. The deterministic solver still requires numeric pixel sizes; add dynamic units after solving." }
      }
    },
    "root": {
      "type": "object",
      "description": "Optional root panel description. If omitted a default full-screen panel is used.",
      "additionalProperties": false,
      "properties": {
        "size": { "$ref": "#/$defs/size" },
        "anchor": { "$ref": "#/$defs/anchor" },
        "pos": { "$ref": "#/$defs/pos" }
      }
    },
    "elements": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/element" }
    },
    "constraints": {
      "type": "array",
      "items": { "$ref": "#/$defs/constraint" },
      "default": []
    }
  },
  "$defs": {
    "anchor": {
      "type": "string",
      "enum": [
        "top_left", "top_middle", "top_right",
        "left_middle", "center", "right_middle",
        "bottom_left", "bottom_middle", "bottom_right"
      ]
    },
    "size": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "oneOf": [
          { "type": "integer", "minimum": 0 },
          { "type": "string", "pattern": "^(default|fill|\\d+%c?m?|\\d+%(x|y|sm)?|\\d+px)$" }
        ]
      },
      "description": "Size as [w, h]. Numbers are solver-ready pixels. Strings document vanilla unit intent but are rejected by the deterministic solve/run pipeline."
    },
    "pos": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": { "type": "integer" },
      "description": "Pixel offset from the chosen anchor. Negative values mean opposite-edge inset."
    },
    "element": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "size"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "parent": { "type": "string", "description": "Parent element id. Defaults to root." },
        "kind": {
          "type": "string",
          "enum": [
            "panel", "image", "label", "button",
            "stack_h", "stack_v",
            "stack_panel", "grid", "collection_grid", "collection_panel", "scroll_view",
            "toggle", "edit_box", "dropdown", "custom"
          ],
          "default": "panel",
          "description": "stack_h / stack_v are sugar for stack_panel with orientation horizontal/vertical."
        },
        "anchor": { "$ref": "#/$defs/anchor", "default": "top_left" },
        "pos": { "$ref": "#/$defs/pos", "default": [0, 0] },
        "size": { "$ref": "#/$defs/size" },
        "auto_size": { "$ref": "#/$defs/auto_size" },
        "collection": { "$ref": "#/$defs/collection" },
        "z": { "type": "integer", "default": 0, "description": "Higher draws on top." },
        "extends": {
          "type": "string",
          "description": "Vanilla preset reference (e.g. 'common_dialogs.main_panel_no_buttons'). When set, the compiled child key becomes 'id@<extends>'.",
          "pattern": "^[a-z][a-z0-9_]*\\.[a-z][a-z0-9_]*$"
        },
        "variables": {
          "type": "object",
          "description": "Preset variables ($-prefixed keys) emitted verbatim onto the compiled control.",
          "additionalProperties": true
        },
        "bindings": {
          "type": "array",
          "description": "JSON UI bindings emitted verbatim. Validated by tools/validate.mjs against data/jsonui-spec.json.",
          "items": { "type": "object" }
        },
        "props": {
          "type": "object",
          "description": "Pass-through JSON UI properties merged at compile time. Use sparingly.",
          "additionalProperties": true
        }
      }
    },
    "auto_size": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["text", "image_aspect", "collection_grid"],
          "description": "Measure and replace size before solving. Use size [0,0] or one fixed axis when the solver should calculate the dimension."
        },
        "axis": {
          "type": "string",
          "enum": ["both", "width", "height"],
          "default": "both"
        },
        "text": {
          "type": "string",
          "description": "Static text to measure. Defaults to props.text when omitted."
        },
        "font_size": {
          "type": "string",
          "enum": ["small", "normal", "large"],
          "description": "Text measurement hint. Defaults to props.font_size or normal."
        },
        "font_scale_factor": {
          "type": "number",
          "minimum": 0.1,
          "description": "Text measurement hint. Defaults to props.font_scale_factor or 1."
        },
        "padding": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 },
          "minItems": 2,
          "maxItems": 2,
          "default": [0, 0],
          "description": "Extra x/y padding added to measured text."
        },
        "aspect": {
          "oneOf": [
            { "type": "number", "exclusiveMinimum": 0 },
            {
              "type": "array",
              "items": { "type": "integer", "minimum": 1 },
              "minItems": 2,
              "maxItems": 2
            }
          ],
          "description": "Image width / height ratio, or [source_w, source_h]."
        },
        "source_size": {
          "type": "array",
          "items": { "type": "integer", "minimum": 1 },
          "minItems": 2,
          "maxItems": 2,
          "description": "Natural image size used when both axes are zero."
        },
        "scale": {
          "type": "number",
          "exclusiveMinimum": 0,
          "default": 1
        },
        "min": { "$ref": "#/$defs/size_px" },
        "max": { "$ref": "#/$defs/size_px" }
      }
    },
    "collection": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Bedrock collection_name, for example form_buttons."
        },
        "dimensions": {
          "type": "array",
          "items": { "type": "integer", "minimum": 1 },
          "minItems": 2,
          "maxItems": 2,
          "description": "Compiled to grid_dimensions."
        },
        "grid_dimensions": {
          "type": "array",
          "items": { "type": "integer", "minimum": 1 },
          "minItems": 2,
          "maxItems": 2,
          "description": "Alias for dimensions."
        },
        "maximum_items": {
          "type": "integer",
          "minimum": 1,
          "description": "Compiled to maximum_grid_items."
        },
        "item_template": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*\\.[a-z][a-z0-9_]*$",
          "description": "Compiled to grid_item_template."
        },
        "item_size": {
          "$ref": "#/$defs/size_px",
          "description": "Solver-only item footprint used by auto_size.mode=collection_grid."
        },
        "gap": {
          "$ref": "#/$defs/pos",
          "description": "Solver-only x/y gap used by auto_size.mode=collection_grid."
        },
        "length_binding": {
          "type": "string",
          "pattern": "^#[A-Za-z0-9_]+$",
          "description": "Optional collection-length binding source, for example #form_button_contents."
        },
        "fill_direction": { "type": "string" },
        "rescaling_type": { "type": "string" }
      }
    },
    "size_px": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": { "type": "integer", "minimum": 0 }
    },
    "constraint": {
      "oneOf": [
        { "$ref": "#/$defs/c_pair" },
        { "$ref": "#/$defs/c_group" },
        { "$ref": "#/$defs/c_gap" },
        { "$ref": "#/$defs/c_edge" }
      ]
    },
    "c_pair": {
      "type": "object",
      "additionalProperties": false,
      "required": ["op", "ids"],
      "properties": {
        "op": {
          "type": "string",
          "enum": ["symmetric_x", "symmetric_y"]
        },
        "about": {
          "type": "string",
          "enum": ["parent_center", "midpoint"],
          "default": "parent_center"
        },
        "ids": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 2,
          "maxItems": 2
        }
      }
    },
    "c_group": {
      "type": "object",
      "additionalProperties": false,
      "required": ["op", "ids"],
      "properties": {
        "op": {
          "type": "string",
          "enum": ["align_x", "align_y", "center_group_x", "center_group_y", "same_size", "same_width", "same_height"]
        },
        "edge": {
          "type": "string",
          "enum": ["start", "center", "end"],
          "default": "start",
          "description": "Used by align_x/align_y. Ignored by center_group_x/center_group_y and same_* constraints."
        },
        "ids": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 2
        }
      }
    },
    "c_gap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["op", "ids"],
      "properties": {
        "op": {
          "type": "string",
          "enum": ["equal_gap_x", "equal_gap_y"]
        },
        "ids": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 3
        },
        "gap": {
          "type": "integer",
          "minimum": 0,
          "description": "If set, forces this exact pixel gap. If omitted, gap is averaged from current positions."
        }
      }
    },
    "c_edge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["op", "a", "b"],
      "properties": {
        "op": {
          "type": "string",
          "enum": ["edge_eq", "edge_offset"]
        },
        "a": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*\\.(left|right|top|bottom|center_x|center_y)$"
        },
        "b": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*\\.(left|right|top|bottom|center_x|center_y)$"
        },
        "delta": {
          "type": "integer",
          "default": 0,
          "description": "Used by edge_offset: a = b + delta."
        }
      }
    }
  }
}
