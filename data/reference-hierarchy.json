{
  "version": 1,
  "purpose": "Hierarchical Bedrock JSON UI routing from user intent to closest docs, references, and patch targets.",
  "flow": [
    "majorTopic",
    "midTopic",
    "subTopic",
    "designFamily",
    "dataSource",
    "style",
    "closestReference",
    "patchTarget"
  ],
  "rules": {
    "openOnlyOneClosestReferenceFirst": true,
    "useVisualFitForLayout": true,
    "userestrictedReferencesAsPatternEvidenceOnly": true,
    "doNotPublishrestrictedNamesOrTexturePaths": true
  },
  "topics": [
