{
  "namespace": "server_form",

  "main_screen_content": {
    "type": "panel",
    "size": ["100%", "100%"],
    "$ssc_form_filter_text": "customUI_SimpleServer_",

    "controls": [
      {
        "default_long_form_panel": {
          "type": "panel",
          "size": ["100%", "100%"],
          "controls": [
            { "default_long_form@server_form.long_form": {} }
          ],
          "bindings": [
            {
              "binding_type": "view",
              "source_property_name": "((#title_text - $ssc_form_filter_text) = #title_text)",
              "target_property_name": "#visible"
            }
          ]
        }
      },

      {
        "default_custom_form_panel": {
          "type": "panel",
          "size": ["100%", "100%"],
          "controls": [
            { "default_custom_form@server_form.custom_form": {} }
          ],
          "bindings": [
            {
              "binding_type": "view",
              "source_property_name": "((#title_text - $ssc_form_filter_text) = #title_text)",
              "target_property_name": "#visible"
            }
          ]
        }
      },

      {
        "ssc_screen_panel": {
          "type": "panel",
          "size": ["100%", "100%"],
          "controls": [
            { "ssc_screen@ssc_form.main_screen_content": {} }
          ],
          "bindings": [
            { "binding_name": "#title_text" },
            {
              "binding_type": "view",
              "source_property_name": "(not ((#title_text - $ssc_form_filter_text) = #title_text))",
              "target_property_name": "#visible"
            }
          ]
        }
      }
    ]
  }
}
