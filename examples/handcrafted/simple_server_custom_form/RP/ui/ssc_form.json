{
  "namespace": "ssc_form",

  "ssc_button_skin": {
    "type": "image",
    "size": [ "100%", "100%" ],
    "texture": "textures/ui/button_borderless_lightgray",
    "tiled": true
  },

  "ssc_button_skin_hover": {
    "type": "image",
    "size": [ "100%", "100%" ],
    "texture": "textures/ui/button_borderless_lighthover",
    "tiled": true
  },

  "ssc_button_skin_pressed": {
    "type": "image",
    "size": [ "100%", "100%" ],
    "texture": "textures/ui/button_borderless_lightpressed",
    "tiled": true
  },

  "ssc_button_label": {
    "type": "label",
    "anchor_from": "bottom_middle",
    "anchor_to": "bottom_middle",
    "offset": [ 0, -10 ],
    "color": [ 1, 1, 1 ],
    "shadow": true,
    "text": "$button_text",
    "font_type": "smooth"
  },

  "ssc_content_button": {
    "type": "button",
    "$pressed_button_name|default": "button.form_button_click",
    "sound_name": "ui.click",
    "sound_volume": 1.0,
    "default_control": "default",
    "hover_control": "hover",
    "pressed_control": "pressed",
    "controls": [
      { "default": { "type": "panel", "controls": [
          { "skin@ssc_form.ssc_button_skin":  {} },
          { "lbl@ssc_form.ssc_button_label":  {} }
      ] } },
      { "hover": { "type": "panel", "controls": [
          { "skin@ssc_form.ssc_button_skin_hover": {} },
          { "lbl@ssc_form.ssc_button_label":       {} }
      ] } },
      { "pressed": { "type": "panel", "controls": [
          { "skin@ssc_form.ssc_button_skin_pressed": {} },
          { "lbl@ssc_form.ssc_button_label":         {} }
      ] } }
    ]
  },

  "ssc_frame_bg": {
    "type": "image",
    "size": [ "100%", "100%" ],
    "texture": "textures/ui/dialog_background_opaque_dark",
    "nineslice_size": [ 8, 8, 8, 8 ],
    "tiled": true,
    "alpha": 1.0
  },

  "ssc_section_bg": {
    "type": "image",
    "size": [ "100%", "100%" ],
    "texture": "textures/ui/Black",
    "alpha": 0.55
  },

  "ssc_scrollbar_track_img": {
    "type": "image",
    "size": [ "100%", "100%" ],
    "texture": "textures/ui/Black",
    "alpha": 0.6
  },

  "ssc_scrollbar_thumb_img": {
    "type": "image",
    "size": [ "100%", "100%" ],
    "texture": "textures/ui/White",
    "alpha": 0.85
  },

  "ssc_title_block": {
    "type": "panel",
    "size": [ 600, 64 ],
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "offset": [ 16, 12 ],
    "controls": [
      { "title": {
          "type": "label",
          "size": [ 600, 32 ],
          "anchor_from": "top_left",
          "anchor_to": "top_left",
          "color": [ 1, 1, 1 ],
          "shadow": true,
          "font_size": "large",
          "text": "#title_text",
          "bindings": [
            { "binding_name": "#title_text" }
          ]
      } },
      { "desc": {
          "type": "label",
          "size": [ 600, 20 ],
          "anchor_from": "top_left",
          "anchor_to": "top_left",
          "offset": [ 0, 36 ],
          "color": [ 0.7, 0.7, 0.7 ],
          "shadow": true,
          "font_type": "smooth",
          "text": "#form_text",
          "bindings": [
            { "binding_name": "#form_text" }
          ]
      } }
    ]
  },

  "ssc_btn1@ssc_form.ssc_content_button": {
    "size": [ 388, 344 ],
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "offset": [ 8, 8 ],
    "$button_text": "Btn1",
    "$pressed_button_name": "button.btn1"
  },
  "ssc_btn2@ssc_form.ssc_content_button": {
    "size": [ 380, 168 ],
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "offset": [ 404, 8 ],
    "$button_text": "Btn2",
    "$pressed_button_name": "button.btn2"
  },
  "ssc_btn3@ssc_form.ssc_content_button": {
    "size": [ 186, 168 ],
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "offset": [ 404, 184 ],
    "$button_text": "Btn3",
    "$pressed_button_name": "button.btn3"
  },
  "ssc_btn4@ssc_form.ssc_content_button": {
    "size": [ 186, 168 ],
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "offset": [ 598, 184 ],
    "$button_text": "Btn4",
    "$pressed_button_name": "button.btn4"
  },

  "ssc_help_button@common.button": {
    "size": [ 40, 40 ],
    "anchor_from": "top_right",
    "anchor_to": "top_right",
    "offset": [ -56, -56 ],
    "$button_text": "?",
    "$pressed_button_name": "button.help"
  },

  "ssc_close_button@common.cancel_button": {
    "size": [ 40, 40 ],
    "anchor_from": "top_right",
    "anchor_to": "top_right",
    "offset": [ -8, -56 ],
    "$pressed_button_name": "button.close"
  },

  "ssc_section1": {
    "type": "panel",
    "size": [ 792, 360 ],
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "controls": [
      { "bg@ssc_form.ssc_section_bg": {} },
      { "btn1@ssc_form.ssc_btn1": {} },
      { "btn2@ssc_form.ssc_btn2": {} },
      { "btn3@ssc_form.ssc_btn3": {} },
      { "btn4@ssc_form.ssc_btn4": {} }
    ]
  },

  "ssc_section2": {
    "type": "panel",
    "size": [ 792, 140 ],
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "offset": [ 0, 372 ],
    "controls": [
      { "bg@ssc_form.ssc_section_bg": {} },
      { "lb_title": {
          "type": "label",
          "size": [ 600, 32 ],
          "anchor_from": "top_left",
          "anchor_to": "top_left",
          "offset": [ 8, 8 ],
          "color": [ 1, 1, 1 ],
          "shadow": true,
          "font_size": "large",
          "text": "Leaderboard"
      } },
      { "lb_desc": {
          "type": "label",
          "size": [ 600, 20 ],
          "anchor_from": "top_left",
          "anchor_to": "top_left",
          "offset": [ 8, 44 ],
          "color": [ 0.7, 0.7, 0.7 ],
          "shadow": true,
          "font_type": "smooth",
          "text": "Description Text!"
      } }
    ]
  },

  "ssc_body": {
    "type": "panel",
    "size": [ 792, 512 ],
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "offset": [ 16, 96 ],
    "controls": [
      { "section1@ssc_form.ssc_section1": {} },
      { "section2@ssc_form.ssc_section2": {} }
    ]
  },

  "ssc_scrollbar": {
    "type": "panel",
    "size": [ 8, 512 ],
    "anchor_from": "top_right",
    "anchor_to": "top_right",
    "offset": [ -8, 96 ],
    "controls": [
      { "track@ssc_form.ssc_scrollbar_track_img": {} },
      { "thumb": {
          "type": "panel",
          "size": [ 8, 220 ],
          "anchor_from": "top_left",
          "anchor_to": "top_left",
          "controls": [
            { "fill@ssc_form.ssc_scrollbar_thumb_img": {} }
          ]
      } }
    ]
  },

  "ssc_frame": {
    "type": "panel",
    "size": [ 840, 624 ],
    "anchor_from": "center",
    "anchor_to": "center",
    "controls": [
      { "bg@ssc_form.ssc_frame_bg":         {} },
      { "title@ssc_form.ssc_title_block":   {} },
      { "body@ssc_form.ssc_body":           {} },
      { "scrollbar@ssc_form.ssc_scrollbar": {} },
      { "help@ssc_form.ssc_help_button":    {} },
      { "close@ssc_form.ssc_close_button":  {} }
    ]
  },

  "main_screen_content": {
    "type": "panel",
    "size": [ "100%", "100%" ],
    "controls": [
      { "frame@ssc_form.ssc_frame": {} }
    ]
  }
}
